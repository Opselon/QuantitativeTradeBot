<UserControl x:Class="Nexus.Desktop.Views.NexusIntelligenceDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nexus.Desktop.Views"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="450">

    <UserControl.Resources>
        <!-- Diagnostic colors -->
        <local:EvaluationBarPositionConverter x:Key="EvaluationBarPositionConverter"/>

        <!-- Elevated Glass Card Style -->
        <Style x:Key="IntelligenceCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderTranslucentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{DynamicResource ShadowBrush}" BlurRadius="12" Direction="270" ShadowDepth="2" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,4,0,0">

            <!-- 1. NEURAL EVALUATION PANEL -->
            <Border Style="{StaticResource IntelligenceCard}">
                <StackPanel>
                    <TextBlock Text="NEURAL EVALUATION DECISION ENGINE" Style="{StaticResource EnterpriseSubHeader}" Foreground="{DynamicResource AccentBrush}"/>

                    <!-- Confidence Output Metrics -->
                    <Grid Margin="0,12,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="BUY CONF" Style="{StaticResource EnterpriseLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding BuyConfidence, StringFormat={}{0:P0}}" Foreground="{DynamicResource SuccessBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="WAIT CONF" Style="{StaticResource EnterpriseLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding WaitConfidence, StringFormat={}{0:P0}}" Foreground="{DynamicResource WarningBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="SELL CONF" Style="{StaticResource EnterpriseLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SellConfidence, StringFormat={}{0:P0}}" Foreground="{DynamicResource DangerBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Consolas"/>
                        </StackPanel>
                    </Grid>

                    <!-- NEXUS EVALUATION BAR -->
                    <TextBlock Text="NEXUS REAL-TIME DECISION BAR" Style="{StaticResource EnterpriseLabel}" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                    <Border Height="24" CornerRadius="6" Margin="0,0,0,12" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource DangerBrush}" Offset="0.0"/> <!-- SELL -->
                                <GradientStop Color="{DynamicResource InteractiveBrush}" Offset="0.5"/> <!-- WAIT -->
                                <GradientStop Color="{DynamicResource SuccessBrush}" Offset="1.0"/> <!-- BUY -->
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Scale indicators -->
                            <TextBlock Grid.Column="0" Text="SELL" Foreground="White" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="WAIT" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="BUY" Foreground="White" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>

                            <!-- Needle pointer / Indicator block bound dynamically -->
                            <Canvas Grid.ColumnSpan="3" x:Name="TrackCanvas">
                                <Border Width="6" Height="26" Background="{DynamicResource AccentBrush}" BorderBrush="White" BorderThickness="1.5" CornerRadius="1" Canvas.Top="-1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Canvas.Left">
                                                <Setter.Value>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <local:EvaluationBarPositionConverter/>
                                                        </MultiBinding.Converter>
                                                        <Binding Path="BuyConfidence"/>
                                                        <Binding Path="SellConfidence"/>
                                                        <Binding ElementName="TrackCanvas" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Canvas>
                        </Grid>
                    </Border>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Model Status:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ModelStatus}" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Evaluation Score:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding EvaluationScore, StringFormat={}{0:F2}}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Inference Time:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding LastInferenceTime}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 2. NATIVE CORE MONITOR PANEL -->
            <Border Style="{StaticResource IntelligenceCard}">
                <StackPanel>
                    <TextBlock Text="NATIVE HIGH-PERFORMANCE INTEL CORE" Style="{StaticResource EnterpriseSubHeader}" Foreground="{DynamicResource AccentBrush}"/>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Native Core Status:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding NativeCoreStatus}" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Library Loaded:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding LibraryLoaded}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="ABI Bridge Version:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding AbiVersion}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Host Platform:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Platform}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="CPU Architecture:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CpuArchitecture}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Active Native Threads:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ActiveNativeThreads}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="RAM Allocation:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding MemoryUsage}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 3. REAL-TIME MARKET INTELLIGENCE DASHBOARD -->
            <Border Style="{StaticResource IntelligenceCard}">
                <StackPanel>
                    <TextBlock Text="MARKET INTELLIGENCE STATE METRICS" Style="{StaticResource EnterpriseSubHeader}" Foreground="{DynamicResource AccentBrush}"/>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Market State:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentMarketState}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Price Structure:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding PriceStructure, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Trend State:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding TrendState, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Momentum Vector:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Momentum, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Volatility Index:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Volatility, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Volume Pressure:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding VolumePressure, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Symmetric Liquidity:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Liquidity, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="USD Strength Score:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding UsdStrength, StringFormat={}{0:F1} / 100}" Foreground="{DynamicResource WarningBrush}" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 4. AI MODEL MONITOR -->
            <Border Style="{StaticResource IntelligenceCard}">
                <StackPanel>
                    <TextBlock Text="AI DEPLOYED NEURAL MODEL MONITOR" Style="{StaticResource EnterpriseSubHeader}" Foreground="{DynamicResource AccentBrush}"/>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Model File Name:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentModelName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Model Version:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ModelVersion}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Load Status:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ModelLoadStatus}" Foreground="{DynamicResource SuccessBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Inference Latency:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding InferenceLatency}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Last Run Timestamp:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding LastExecutionTimestamp}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 5. PERFORMANCE METRIC MONITOR -->
            <Border Style="{StaticResource IntelligenceCard}">
                <StackPanel>
                    <TextBlock Text="LATENCY &amp; METADATA ENGINE METRICS" Style="{StaticResource EnterpriseSubHeader}" Foreground="{DynamicResource AccentBrush}"/>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Native Compute Latency:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding NativeExecutionLatency}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="CLR Native Interop:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding InteropLatency}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Feature Generation Time:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding FeatureCalculationTime}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Neural Inference:" Style="{StaticResource EnterpriseLabel}"/>
                        <TextBlock Grid.Column="1" Text="{Binding NeuralInferenceTime}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                    </Grid>

                    <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderTranslucentBrush}" Margin="0,8,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Total Pipeline Duration:" Style="{StaticResource EnterpriseLabel}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalDecisionPipelineTime}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" FontFamily="Consolas"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
