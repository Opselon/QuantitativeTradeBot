<UserControl x:Class="Nexus.Desktop.Views.NexusIntelligenceDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nexus.Desktop.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="450">

    <UserControl.Resources>
        <!-- Custom needle pointer converter mapped locally -->
        <local:EvaluationBarPositionConverter x:Key="EvaluationBarPositionConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
        <StackPanel>

            <!-- 1. NEURAL EVALUATION DECISION PANEL -->
            <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="NEURAL EVALUATION DECISION MATRIX" Style="{StaticResource NteTitleLarge}" Margin="0,0,0,15"/>

                    <!-- Confidence Meters -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="BUY CONF" Style="{StaticResource NteLabelSmall}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding BuyConfidence, StringFormat={}{0:P0}}" Foreground="{DynamicResource SuccessBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource LightSuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="WAIT CONF" Style="{StaticResource NteLabelSmall}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding WaitConfidence, StringFormat={}{0:P0}}" Foreground="{DynamicResource WarningBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource LightWarningBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="SELL CONF" Style="{StaticResource NteLabelSmall}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SellConfidence, StringFormat={}{0:P0}}" Foreground="{DynamicResource ErrorBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource LightErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- NEXUS DECISION NEEDLE BAR -->
                    <TextBlock Text="REAL-TIME NEEDLE PROJECTION BAR" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,8" HorizontalAlignment="Center"/>

                    <Border Height="26" CornerRadius="12" Margin="0,0,0,15" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#EF4444" Offset="0.0"/>
                                <GradientStop Color="#1F2937" Offset="0.5"/>
                                <GradientStop Color="#22C55E" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="SELL" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="WAIT" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="BUY" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>

                            <!-- Dynamic Needle Indicator -->
                            <Canvas Grid.ColumnSpan="3" x:Name="TrackCanvas">
                                <Border Width="6" Height="28" Background="{DynamicResource PrimaryBrush}" BorderBrush="White" BorderThickness="1.5" CornerRadius="2" Canvas.Top="-1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Canvas.Left">
                                                <Setter.Value>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <local:EvaluationBarPositionConverter/>
                                                        </MultiBinding.Converter>
                                                        <Binding Path="BuyConfidence"/>
                                                        <Binding Path="SellConfidence"/>
                                                        <Binding ElementName="TrackCanvas" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Canvas>
                        </Grid>
                    </Border>

                    <!-- Indicators Meta -->
                    <Grid Margin="5,5,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Model Mode/Status:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ModelStatus}" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteBodyLarge}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightSuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Evaluation Score:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding EvaluationScore, StringFormat={}{0:F2}}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="5,0,5,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Inference Latency:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding LastInferenceTime}" Style="{StaticResource NteTradingDataFont}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- 1b. STOCKFISH DECISION SEARCH & MTF CONSENSUS -->
            <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="STOCKFISH 18 DECISION INTELLIGENCE" Style="{StaticResource NteTitleLarge}" Margin="0,0,0,15"/>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Search Best Move:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding SearchBestAction}" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteBodyLarge}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchBestAction}" Value="WAIT">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchBestAction}" Value="SELL">
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="5,0,5,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Search Evaluation:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="1" Text="{Binding SearchReasoning}" Style="{StaticResource NteBodyLarge}" TextWrapping="Wrap" VerticalAlignment="Top"/>
                    </Grid>

                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GlassBorderBrush}" Margin="0,0,0,10"/>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="MTF Consensus:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="1" Text="{Binding MtfConsensusSummary}" Style="{StaticResource NteBodyLarge}" TextWrapping="Wrap" VerticalAlignment="Top" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- 2. NATIVE PERFORMANCE CORE -->
            <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="NATIVE ACCELERATED INTEL CORE" Style="{StaticResource NteTitleLarge}" Margin="0,0,0,15"/>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Native Core Status:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding NativeCoreStatus}" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteBodyLarge}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightSuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="ABI Core Loaded:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding LibraryLoaded}" Style="{StaticResource NteBodyLarge}" TextWrapping="Wrap"/>
                    </Grid>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="ABI Specification:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding AbiVersion}" Style="{StaticResource NteTradingDataFont}"/>
                    </Grid>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="RAM Heap Alloc:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding MemoryUsage}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- 3. REAL-TIME MARKET STATE METRICS -->
            <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="MARKET INTELLIGENCE CONTEXT" Style="{StaticResource NteTitleLarge}" Margin="0,0,0,15"/>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Market State:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentMarketState}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteBodyLarge}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Trend Parameter:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding TrendState, StringFormat={}{0:F2}}" Style="{StaticResource NteTradingDataFont}"/>
                    </Grid>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Momentum Vector:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Momentum, StringFormat={}{0:F2}}" Style="{StaticResource NteTradingDataFont}"/>
                    </Grid>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Symmetric Liquidity:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Liquidity, StringFormat={}{0:F2}}" Style="{StaticResource NteTradingDataFont}"/>
                    </Grid>

                    <Grid Margin="5,0,5,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Relative Strength:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding UsdStrength, StringFormat={}{0:F1} / 100}" Foreground="{DynamicResource WarningBrush}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightWarningBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- 4. PIPELINE DURATIONS METRICS -->
            <materialDesign:Card Style="{StaticResource NtePremiumCard}">
                <StackPanel>
                    <TextBlock Text="PIPELINE CALCULATION METRICS" Style="{StaticResource NteTitleLarge}" Margin="0,0,0,15"/>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Native Compute Latency:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding NativeExecutionLatency}" Style="{StaticResource NteTradingDataFont}"/>
                    </Grid>

                    <Grid Margin="5,0,5,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="CLR Interop Handshake:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding InteropLatency}" Style="{StaticResource NteTradingDataFont}"/>
                    </Grid>

                    <Grid Margin="5,0,5,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Inference Latency:" Style="{StaticResource NteLabelLarge}"/>
                        <TextBlock Grid.Column="1" Text="{Binding NeuralInferenceTime}" Style="{StaticResource NteTradingDataFont}"/>
                    </Grid>

                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GlassBorderBrush}" Margin="0,0,0,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource LightGlassBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <Grid Margin="5,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Total Pipeline Duration:" Style="{StaticResource NteLabelLarge}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalDecisionPipelineTime}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
