<UserControl x:Class="Nexus.Desktop.Views.Workspaces.MarketWatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 1. Top Header -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <!-- 2. Bloomberg-Style Market Watch Grid -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Premium Watchlist Header Card -->
        <materialDesign:Card Grid.Row="0" Style="{StaticResource NtePremiumCard}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="Eye" Width="36" Height="36" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,15,0">
                    <materialDesign:PackIcon.Style>
                        <Style TargetType="materialDesign:PackIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource LightPrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialDesign:PackIcon.Style>
                </materialDesign:PackIcon>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="NEXUS REAL-TIME FEED WATCHLIST" Style="{StaticResource NteHeadline}" Margin="0,0,0,3"/>
                    <TextBlock Text="Continuous high-frequency tick streams monitoring and direct symbol ingestion control matrices." Style="{StaticResource NteBodyMedium}"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Bloomberg-Style Market Data Watch Grid -->
        <materialDesign:Card Grid.Row="2" Style="{StaticResource NtePremiumCard}">
            <DataGrid ItemsSource="{Binding SubscribedSymbolsList}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}" Background="{DynamicResource BackgroundBrush}" RowBackground="{DynamicResource SurfaceContainerBrush}" AlternatingRowBackground="{DynamicResource SurfaceBrush}">
                <DataGrid.Style>
                    <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LightGlassBorderBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource LightGlassBorderBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}"/>
                                <Setter Property="RowBackground" Value="{DynamicResource LightSurfaceContainerBrush}"/>
                                <Setter Property="AlternatingRowBackground" Value="{DynamicResource LightSurfaceBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Style>
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="FontFamily" Value="Segoe UI Variable, Inter"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource LightSurfaceVariantBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource LightTextSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="FontFamily" Value="Segoe UI Variable, Inter"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource LightTextPrimaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Instrument" Binding="{Binding SymbolName}" Width="150" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Subscribed Status" Binding="{Binding IsSubscribed}" Width="150"/>
                    <DataGridTextColumn Header="Bid Price" Binding="{Binding Bid, StringFormat={}{0:F5}}" Width="140" ElementStyle="{StaticResource NteTradingDataFont}"/>
                    <DataGridTextColumn Header="Ask Price" Binding="{Binding Ask, StringFormat={}{0:F5}}" Width="140" ElementStyle="{StaticResource NteTradingDataFont}"/>
                    <DataGridTextColumn Header="Spread" Binding="{Binding Spread, StringFormat={}{0:F5}}" Width="130" ElementStyle="{StaticResource NteTradingDataFont}"/>
                    <DataGridTextColumn Header="Total Ticks" Binding="{Binding TickCount}" Width="120" ElementStyle="{StaticResource NteTradingDataFont}"/>
                    <DataGridTextColumn Header="Last Updated" Binding="{Binding LastUpdateTimeText}" Width="180" ElementStyle="{StaticResource NteTradingDataFont}"/>
                    <DataGridTemplateColumn Header="Action Routing" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="SUBSCRIBE" Command="{Binding DataContext.ToggleSubscriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Height="28" FontSize="11" Padding="12,0" HorizontalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource BackgroundBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSubscribed}" Value="True">
                                                    <Setter Property="Content" Value="UNSUBSCRIBE"/>
                                                    <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True"/>
                                                        <Condition Binding="{Binding IsSubscribed}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LightPrimaryBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource LightSurfaceContainerBrush}"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True"/>
                                                        <Condition Binding="{Binding IsSubscribed}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="{DynamicResource LightErrorBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LightErrorBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>
