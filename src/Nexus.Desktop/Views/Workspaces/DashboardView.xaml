                                                                            <Setter Property="Background" Value="#EF4444"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransitionType}" Value="CLOSE">
                                                                            <Setter Property="Background" Value="#6B7280"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransitionType}" Value="WAIT">
                                                                            <Setter Property="Background" Value="#F59E0B"/>
                                                                        </DataTrigger>
