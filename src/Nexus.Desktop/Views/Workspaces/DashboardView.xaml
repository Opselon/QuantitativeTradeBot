                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SingleExposureUtilizationColor}" Value="#F59E0B">
                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SingleExposureUtilizationColor}" Value="#EF4444">
