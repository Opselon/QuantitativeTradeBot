                                            <TextBlock Text="{Binding}" Foreground="#F87171" FontSize="10" FontFamily="Consolas" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- =================================================== -->
                    <!-- EXPLAINABILITY TIMELINE PANEL                       -->
                    <!-- =================================================== -->
                    <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,15">
