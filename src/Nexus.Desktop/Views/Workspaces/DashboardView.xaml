<UserControl x:Class="Nexus.Desktop.Views.Workspaces.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Nexus.Desktop.Converters"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded"
             d:DesignHeight="1800" d:DesignWidth="1440">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:EqualityToBooleanConverter x:Key="EqualityToBooleanConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <!-- Header section -->
            <RowDefinition Height="Auto"/>
            <!-- Health Monitor horizontal ribbon -->
            <RowDefinition Height="Auto"/>
            <!-- Main Grid content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Command Center Header Banner -->
        <materialDesign:Card Grid.Row="0" Style="{StaticResource NtePremiumCard}" Padding="25,15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon Kind="ShieldLock" Width="40" Height="40" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="INSTITUTIONAL QUANTITATIVE COMMAND WORKSTATION" Style="{StaticResource NteHeadline}" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="Real-time multi-dimensional neural state matrices, scenario utility evaluations, bare-metal C++ indicators performance and execution monitors." Style="{StaticResource NteBodyMedium}"/>
                </StackPanel>

                <!-- Active symbol tag -->
                <Border Grid.Column="2" Background="{DynamicResource PrimaryContainerBrush}" CornerRadius="8" BorderThickness="1.5" BorderBrush="{DynamicResource PrimaryBrush}" Padding="15,6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartTimelineVariant" Width="16" Height="16" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding CurrentSymbol}" Foreground="{DynamicResource PrimaryBrush}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </materialDesign:Card>

        <!-- =================================================== -->
        <!-- SYSTEM HEALTH MONITOR HORIZONTAL RIBBON             -->
        <!-- =================================================== -->
        <materialDesign:Card Grid.Row="1" Style="{StaticResource NtePremiumCard}" Padding="20,12" Margin="0,0,0,15" Background="{DynamicResource SurfaceContainerBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Subsystem Lamps -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.5"/>
                    <!-- Resource Performance Monitors -->
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <!-- Subsystem Status Lamps -->
                <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="HEALTH MONITOR:" Style="{StaticResource NteLabelSmall}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <!-- Native Engine Lamp -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" ToolTip="High performance C++20 Core Indicator library status.">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="NATIVE" FontSize="11" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Decision Engine Lamp -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" ToolTip="Autonomous Decision intelligence pipeline state.">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="DECISION" FontSize="11" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Market Intelligence Lamp -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" ToolTip="Multi-timeframe consensus data-fusion state.">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="INTELLIGENCE" FontSize="11" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Training Engine Lamp -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center" ToolTip="Self-learning and validation engine pipeline status.">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="LEARNING" FontSize="11" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Execution Engine Lamp -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" ToolTip="RiskControlledExecutionEngine safety gates and order dispatcher.">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="EXECUTION" FontSize="11" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Database Lamp -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" ToolTip="Local persistence layers and schema indexing connectivity.">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="DATABASE" FontSize="11" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- MT5 Bridge Lamp -->
                    <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Center" ToolTip="Active TCP localhost bridge with expert advisor script.">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="MT5 BRIDGE" FontSize="11" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Thin Separator -->
                <Border Grid.Column="1" Background="{DynamicResource GlassBorderBrush}"/>

                <!-- Real-time performance monitors (Monospace / Monofont latencies) -->
                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" ToolTip="Tick ingestion and indicator pipeline processing latency.">
                        <TextBlock Text="TICK LATENCY" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TickProcessingLatencyMs, StringFormat={}{0:F3} ms}" FontSize="13" FontWeight="Bold" Foreground="#10B981" Style="{StaticResource NteTradingDataFont}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" ToolTip="Scenario search tree search and consensus decision pipeline latency.">
                        <TextBlock Text="DECISION LATENCY" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DecisionLatencyMs, StringFormat={}{0:F2} ms}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Style="{StaticResource NteTradingDataFont}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" ToolTip="Order submission and MT5 execution dispatcher response latency.">
                        <TextBlock Text="EXECUTION LATENCY" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ExecutionLatencyMs, StringFormat={}{0:F1} ms}" FontSize="13" FontWeight="Bold" Foreground="#EF4444" Style="{StaticResource NteTradingDataFont}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <!-- Main Workstation Layout Split -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Left: Intelligence, Decisions, Scenarios, Replay, Events -->
                    <ColumnDefinition Width="*"/>
                    <!-- Gap -->
                    <ColumnDefinition Width="15"/>
                    <!-- Right: Execution, Training, Timeline -->
                    <ColumnDefinition Width="500"/>
                </Grid.ColumnDefinitions>

                <!-- ========================================== -->
                <!-- LEFT PANELS                                -->
                <!-- ========================================== -->
                <StackPanel Grid.Column="0">

                    <!-- 1. Market Intelligence Panel -->
                    <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <materialDesign:PackIcon Kind="GoogleAnalytics" Width="22" Height="22" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="MARKET INTELLIGENCE MATRIX" Style="{StaticResource NteTitleLarge}" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#1D4ED8" CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="{Binding MarketRegime}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </Grid>

                            <Grid Margin="5,0,5,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>

                                <!-- Score -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="QUALITY SCORE" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MarketQualityScore, StringFormat={}{0}/100}" Foreground="#10B981" FontSize="24" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- Liquidity -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="LIQUIDITY" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Liquidity, StringFormat={}{0:P1}}" Foreground="{DynamicResource PrimaryBrush}" FontSize="24" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- Volatility -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="VOLATILITY" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Volatility, StringFormat={}{0:P1}}" Foreground="#F59E0B" FontSize="24" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- Momentum -->
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="MOMENTUM" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Momentum, StringFormat={}{0:P1}}" Foreground="{DynamicResource SecondaryBrush}" FontSize="24" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Real-Time Sparkline Vector Plotting -->
                                <StackPanel Grid.Column="4" Margin="15,0,0,0" ToolTip="Real-time scrolling tick sparkline.">
                                    <TextBlock Text="REAL-TIME SPARKLINE" Style="{StaticResource NteLabelSmall}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <Border BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}" Background="#090D14" CornerRadius="4" Height="40">
                                        <Canvas Width="180" Height="40" ClipToBounds="True">
                                            <Polyline Points="{Binding SparklinePoints}" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="1.5"/>
                                        </Canvas>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GlassBorderBrush}" Margin="0,0,0,12"/>

                            <!-- Multi-Timeframe Alignment Consensus -->
                            <TextBlock Text="MULTI-TIMEFRAME ALIGNMENT BIAS" Style="{StaticResource NteLabelLarge}" FontWeight="Bold" Margin="5,0,0,10"/>
                            <Grid Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="6" Padding="12,8" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}">
                                    <StackPanel>
                                        <TextBlock Text="D1 TREND" Style="{StaticResource NteLabelSmall}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding D1Consensus}" Foreground="#10B981" FontSize="15" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="6" Padding="12,8" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}">
                                    <StackPanel>
                                        <TextBlock Text="H4 MOMENTUM" Style="{StaticResource NteLabelSmall}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding H4Consensus}" Foreground="#10B981" FontSize="15" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="6" Padding="12,8" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}">
                                    <StackPanel>
                                        <TextBlock Text="M15 ENTRY TIMING" Style="{StaticResource NteLabelSmall}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding M15Consensus}" Foreground="{DynamicResource PrimaryBrush}" FontSize="15" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Text="{Binding ConsensusSummary}" Style="{StaticResource NteBodyMedium}" Margin="5,12,0,0" FontStyle="Italic" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- 2. AI Decision Panel -->
                    <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <materialDesign:PackIcon Kind="Brain" Width="22" Height="22" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="AI NEURAL DECISION MATRIX" Style="{StaticResource NteTitleLarge}" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#047857" CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="{Binding CurrentDecision}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                </Border>
                            </Grid>

                            <Grid Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="CONFIDENCE" Style="{StaticResource NteLabelSmall}"/>
                                    <TextBlock Text="{Binding Confidence, StringFormat={}{0:P1}}" Foreground="#10B981" FontSize="32" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding ExpectedValue}" Style="{StaticResource NteBodyMedium}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="1" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource GlassBorderBrush}" Margin="10,0"/>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="SUPPORTING QUANT EVIDENCE" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,6"/>
                                    <ItemsControl ItemsSource="{Binding SupportingEvidence}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <materialDesign:PackIcon Kind="ChevronRight" Width="14" Height="14" Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource NteBodyMedium}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="REJECTED ALTERNATIVES" Style="{StaticResource NteLabelSmall}" Margin="0,12,0,6"/>
                                    <ItemsControl ItemsSource="{Binding RejectedAlternatives}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource NteBodyMedium}" TextDecorations="Strikethrough" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- 3. Scenario Search Visualization & WHAT-IF Simulation -->
                    <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="GraphOutline" Width="22" Height="22" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="STOCKFISH SCENARIO TREE &amp; WHAT-IF SIMULATOR" Style="{StaticResource NteTitleLarge}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="340"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Side: EXPECTED UTILITY PROGRESS BARS (Bound to simulated values) -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="EXPECTED UTILITY SCALE OF CANDIDATE ACTIONS (EV)" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,10"/>

                                    <!-- BUY expected utility -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="BUY" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding BuyExpectedUtility, Mode=OneWay}" Minimum="-10" Maximum="10" Height="10" Foreground="#10B981" Background="{DynamicResource SurfaceVariantBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding BuyExpectedUtility, StringFormat={}{0:F2} EV}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource NteTradingDataFont}" Foreground="#10B981"/>
                                    </Grid>

                                    <!-- SELL expected utility -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="SELL" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding SellExpectedUtility, Mode=OneWay}" Minimum="-10" Maximum="10" Height="10" Foreground="#EF4444" Background="{DynamicResource SurfaceVariantBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding SellExpectedUtility, StringFormat={}{0:F2} EV}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource NteTradingDataFont}" Foreground="#EF4444"/>
                                    </Grid>

                                    <!-- WAIT expected utility -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="WAIT" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding WaitExpectedUtility, Mode=OneWay}" Minimum="-10" Maximum="10" Height="10" Foreground="#3B82F6" Background="{DynamicResource SurfaceVariantBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding WaitExpectedUtility, StringFormat={}{0:F2} EV}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource NteTradingDataFont}" Foreground="#3B82F6"/>
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Column="1" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource GlassBorderBrush}" Margin="10,0"/>

                                <!-- Live scenario provenance; no interactive override can alter a production decision. -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="LIVE SCENARIO PROVENANCE" Style="{StaticResource NteLabelSmall}" Foreground="#10B981" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Candidate utilities are emitted by the native evaluator, decision pipeline, and risk gate from the latest MT5 snapshot." FontSize="10.5" Style="{StaticResource NteBodyMedium}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontStyle="Italic"/>
                                </StackPanel>
                            </Grid>
                            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource GlassBorderBrush}" Margin="0,10,0,10"/>

                            <TextBlock Text="ENGINE SELECTION REASONING" Style="{StaticResource NteLabelSmall}" Margin="5,0,0,6"/>
                            <TextBlock Text="{Binding SelectionReason}" Style="{StaticResource NteBodyMedium}" Foreground="{DynamicResource TextSecondaryBrush}" FontStyle="Italic" TextWrapping="Wrap" Margin="5,0"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- =================================================== -->
                    <!-- DECISION REPLAY MASTER-DETAIL PANEL                 -->
                    <!-- =================================================== -->
                    <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="History" Width="22" Height="22" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="DETERMINISTIC DECISION REPLAY MONITOR" Style="{StaticResource NteTitleLarge}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- Left: Master Decision List (Scrollable list of historical events) -->
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="15"/>
                                    <!-- Right: Detail view (reconstructed reasoning metrics) -->
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Master list -->
                                <Border Grid.Column="0" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}" CornerRadius="6" Background="#0C0F17" Padding="4" Height="280">
                                    <ListBox ItemsSource="{Binding HistoricalDecisions}" SelectedItem="{Binding SelectedReplayDecision}" Background="Transparent" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="5,6">
                                                    <TextBlock Text="{Binding DecisionName}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <!-- Detail pane -->
                                <Border Grid.Column="2" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}" CornerRadius="6" Background="{DynamicResource SurfaceContainerBrush}" Padding="15,12" Height="280">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Visibility="{Binding IsReplayDetailVisible, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock Text="RECONSTRUCTED DECISION REASONING STATE" Style="{StaticResource NteLabelSmall}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" Margin="0,0,0,10"/>

                                            <!-- Snapshot and Regime -->
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Market Snapshot:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ReplayMarketSnapshot}" Style="{StaticResource NteBodyMedium}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Market Regime:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ReplayMarketRegime}" Foreground="#F59E0B" Style="{StaticResource NteBodyMedium}" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Feature Vector summary:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ReplayFeatureVectorSummary}" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,6">
