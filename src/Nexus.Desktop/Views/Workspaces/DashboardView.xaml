                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="4" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="4" Padding="8,5">
                                    <StackPanel>
                                        <TextBlock Text="PF FACTOR" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding ProfitFactor, StringFormat={}{0:F2}}" Foreground="#10B981" FontSize="13" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="4" Padding="8,5">
                                    <StackPanel>
                                        <TextBlock Text="MAX DD" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding TrainingMaxDrawdown, StringFormat={}{0:F1}%}" Foreground="#EF4444" FontSize="13" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="4" Padding="8,5">
                                    <StackPanel>
                                        <TextBlock Text="LOSS CONV" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding LossConvergence, StringFormat={}{0:F4}}" Foreground="#F59E0B" FontSize="13" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="4" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="4" Padding="8,5">
                                    <StackPanel>
                                        <TextBlock Text="VALID GATES" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="4/4 PASSED" Foreground="#10B981" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- 6. Native Engine Monitor -->
                    <materialDesign:Card Style="{StaticResource NtePremiumCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="Cpu64Bit" Width="22" Height="22" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="BARE-METAL NATIVE C++ PERFORMANCE" Style="{StaticResource NteTitleLarge}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- CPU -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Native CPU Usage:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CpuUsage, StringFormat={}{0:F1}%}" Foreground="{DynamicResource PrimaryBrush}" FontSize="14" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" VerticalAlignment="Center"/>

                                <!-- Speed -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Evaluation Speed:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EvaluationSpeed, StringFormat={}{0:N0} evals/sec}" Foreground="#10B981" FontSize="14" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" VerticalAlignment="Center"/>

                                <!-- Features -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Features Recalcs:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FeaturesPerSec, StringFormat={}{0:N0} features/sec}" Style="{StaticResource NteTradingDataFont}" VerticalAlignment="Center"/>

                                <!-- Latency -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Ingress Latency:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LatencyMs, StringFormat={}{0:F5} ms}" Foreground="#F59E0B" FontSize="14" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" VerticalAlignment="Center"/>

                                <!-- Thread Status -->
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Threading Status:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ThreadStatus}" Style="{StaticResource NteBodyMedium}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>