                                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CumulativeExposureUtilizationColor}" Value="#F59E0B">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CumulativeExposureUtilizationColor}" Value="#EF4444">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar Value="{Binding CumulativeExposureUtilization, Mode=OneWay}" Height="6" Background="{DynamicResource SurfaceVariantBrush}" Margin="0,4,0,0">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar">
                                                <Setter Property="Foreground" Value="#10B981"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CumulativeExposureUtilizationColor}" Value="#F59E0B">
                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CumulativeExposureUtilizationColor}" Value="#EF4444">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>
                                </StackPanel>
                            </StackPanel>

                            <!-- Account metrics grid -->
                            <Grid Margin="5,0,5,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Balance -->
                                <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="6" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="BALANCE" Style="{StaticResource NteLabelSmall}"/>
                                        <TextBlock Text="{Binding AccountBalance, StringFormat={}{0:C2}}" Foreground="#10B981" FontSize="16" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Equity -->
                                <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="6" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="EQUITY" Style="{StaticResource NteLabelSmall}"/>
                                        <TextBlock Text="{Binding AccountEquity, StringFormat={}{0:C2}}" Foreground="#10B981" FontSize="16" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Margin -->
                                <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="6" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="MARGIN" Style="{StaticResource NteLabelSmall}"/>
                                        <TextBlock Text="{Binding MarginUsed, StringFormat={}{0:C2}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Exposure -->
                                <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource SurfaceVariantBrush}" CornerRadius="6" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="EXPOSURE" Style="{StaticResource NteLabelSmall}"/>
                                        <TextBlock Text="{Binding CumulativeExposure, StringFormat={}{0:C2}}" Foreground="#F59E0B" FontSize="15" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" Margin="0,4,0,0"/>
