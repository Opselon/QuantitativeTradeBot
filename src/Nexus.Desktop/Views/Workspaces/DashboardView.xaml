                                        <TextBlock Text="{Binding MaxDrawdown, StringFormat={}{0:P1}}" Foreground="#EF4444" FontSize="15" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

