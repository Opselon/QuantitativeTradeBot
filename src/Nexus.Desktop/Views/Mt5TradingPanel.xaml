<UserControl x:Class="Nexus.Desktop.Views.Mt5TradingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nexus.Desktop.Views"
             xmlns:converters="clr-namespace:Nexus.Desktop.Converters"
             xmlns:vm="clr-namespace:Nexus.Desktop.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:ProfitToBrushConverter x:Key="ProfitToBrushConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 1. Connection Monitoring -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <!-- 2. Manual Order Entry (Redesigned Buy/Sell ticket) -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <!-- 3. Active Positions -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. Connection Monitoring widgets -->
        <materialDesign:Card Grid.Row="0" Style="{StaticResource NtePremiumCard}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Current Mode -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="GATEWAY PROFILE" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CurrentMode, FallbackValue='Simulation'}" Foreground="{DynamicResource PrimaryBrush}" FontSize="15" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource LightPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Connection State with Pulsing / Glow Indicator -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="BRIDGE STATE" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True"/>
                                                <Condition Binding="{Binding IsConnected}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Fill" Value="{DynamicResource LightErrorBrush}"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True"/>
                                                <Condition Binding="{Binding IsConnected}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Fill" Value="{DynamicResource LightSuccessBrush}"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatusText, FallbackValue='Disconnected'}" Style="{StaticResource NteBodyLarge}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Bridge Active status -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="SOCKET LISTEN" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <TextBlock Text="Listening / Active" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NteBodyLarge}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                        <Setter Property="Text" Value="Inactive"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True"/>
                                            <Condition Binding="{Binding IsConnected}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource LightTextSecondaryBrush}"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Last response -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="ROUND TRIP LATENCY" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding LastResponseTimeText, FallbackValue='0 ms'}" Style="{StaticResource NteTradingDataFont}" FontWeight="Bold"/>
                </StackPanel>

                <!-- Refresh rate -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="LAST SYNCED TIME" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding LastSuccessfulRefreshText, FallbackValue='Never'}" Style="{StaticResource NteBodyLarge}"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- 2. Manual Order Entry -->
        <materialDesign:Card Grid.Row="2" Style="{StaticResource NtePremiumCard}">
            <StackPanel>
                <TextBlock Text="MANUAL ORDER TICK &amp; DYNAMIC RISK ENTRY" Style="{StaticResource NteTitleLarge}" Margin="0,0,0,20"/>

                <Grid Margin="10,0,10,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0: Inputs -->
                    <!-- Editable ComboBox allowing typing or selecting from list -->
                    <ComboBox Grid.Row="0" Grid.Column="0" 
                              Text="{Binding SelectedSymbol, UpdateSourceTrigger=PropertyChanged}" 
                              ItemsSource="{Binding AvailableSymbols}"
                              IsEditable="True"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              materialDesign:HintAssist.Hint="Trading Instrument Symbol (e.g. EURUSD)"/>

                    <!-- Order volume lots input -->
                    <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding OrderVolume, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}" materialDesign:HintAssist.Hint="Trade Position Volume Lots (e.g. 0.10)"/>

                    <!-- Trailing Stop (Pips) -->
                    <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding TrailingStopPips, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}" materialDesign:HintAssist.Hint="Dynamic Trailing Stop (Pips, e.g. 15)"/>

                    <!-- Row 2: SL/TP and Action Buttons -->
                    <!-- Stop Loss (Pips) -->
                    <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding StopLossPips, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}" materialDesign:HintAssist.Hint="Virtual Stop Loss (Pips, e.g. 20)"/>

                    <!-- Take Profit (Pips) -->
                    <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding TakeProfitPips, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}" materialDesign:HintAssist.Hint="Virtual Take Profit (Pips, e.g. 40)"/>

                    <!-- BUY/SELL Operation Panel -->
                    <Grid Grid.Row="2" Grid.Column="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- BUY Button -->
                        <Button Grid.Column="0" Content="BUY" Command="{Binding BuyCommand}" Height="40" AutomationProperties.Name="BuyButton">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource LightSuccessBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource LightSuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- SELL Button -->
                        <Button Grid.Column="2" Content="SELL" Command="{Binding SellCommand}" Height="40" AutomationProperties.Name="SellButton">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                    <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource LightErrorBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource LightErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Grid>

                <!-- Feedback messaging -->
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" FontWeight="Bold" FontSize="13" Margin="0,0,20,0" VerticalAlignment="Center" Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource WarningBrush}" FontSize="13" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightWarningBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1" Content="CLEAR ERRORS" Command="{Binding ClearErrorCommand}" Style="{StaticResource NteSecondaryButton}" Height="30" Padding="12,0" FontSize="11" Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"/>
                </Grid>
            </StackPanel>
        </materialDesign:Card>
        <!-- 3. Active positions grid -->
        <materialDesign:Card Grid.Row="4" Style="{StaticResource NtePremiumCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Title -->
                    <RowDefinition Height="15"/>
                    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- Aggregated Real-time Metrics Summary Bar -->
                    <RowDefinition Height="15"/>
                    <!-- Spacer -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                    <RowDefinition Height="15"/>
                    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- Actions -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ACTIVE TERMINAL POSITIONS" Style="{StaticResource NteTitleLarge}"/>

                <!-- Real-time Summary Indicators -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Net Profit Card -->
                    <Border Grid.Column="0" Background="{DynamicResource SurfaceContainerBrush}" CornerRadius="6" Padding="15,10" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}">
                        <StackPanel>
                            <TextBlock Text="NET CURRENT P&amp;L" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalProfit, StringFormat={}{0:C2}}" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI Variable, Inter" Foreground="{Binding TotalProfit, Converter={StaticResource ProfitToBrushConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Active Win Rate Card -->
                    <Border Grid.Column="2" Background="{DynamicResource SurfaceContainerBrush}" CornerRadius="6" Padding="15,10" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}">
                        <StackPanel>
                            <TextBlock Text="ACTIVE WIN RATE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI Variable, Inter" Foreground="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Winning Trades Card -->
                    <Border Grid.Column="4" Background="{DynamicResource SurfaceContainerBrush}" CornerRadius="6" Padding="15,10" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}">
                        <StackPanel>
                            <TextBlock Text="WINNING TRADES" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalWins}" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI Variable, Inter" Foreground="{DynamicResource SuccessBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Losing Trades Card -->
                    <Border Grid.Column="6" Background="{DynamicResource SurfaceContainerBrush}" CornerRadius="6" Padding="15,10" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}">
                        <StackPanel>
                            <TextBlock Text="LOSING TRADES" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalLosses}" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI Variable, Inter" Foreground="{DynamicResource ErrorBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Open Volume Card -->
                    <Border Grid.Column="8" Background="{DynamicResource SurfaceContainerBrush}" CornerRadius="6" Padding="15,10" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}">
                        <StackPanel>
                            <TextBlock Text="TOTAL OPEN LOTS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalVolume, StringFormat={}{0:F2} Lots}" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI Variable, Inter" Foreground="{DynamicResource WarningBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Modern Datagrid for Positions (shifted to Grid.Row 4) -->
                <DataGrid Grid.Row="4" ItemsSource="{Binding OpenPositions}" SelectedItem="{Binding SelectedPosition}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}" Background="{DynamicResource BackgroundBrush}" RowBackground="{DynamicResource SurfaceContainerBrush}" AlternatingRowBackground="{DynamicResource SurfaceBrush}">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LightGlassBorderBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource LightGlassBorderBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}"/>
                                    <Setter Property="RowBackground" Value="{DynamicResource LightSurfaceContainerBrush}"/>
                                    <Setter Property="AlternatingRowBackground" Value="{DynamicResource LightSurfaceBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontFamily" Value="Segoe UI Variable, Inter"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource LightSurfaceVariantBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource LightTextSecondaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="FontFamily" Value="Segoe UI Variable, Inter"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource LightTextPrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ticket" Binding="{Binding Ticket}" Width="85" FontWeight="SemiBold" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="85" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="75"/>
                        <DataGridTextColumn Header="Volume" Binding="{Binding Volume, StringFormat={}{0:F2}}" Width="85" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Open Price" Binding="{Binding OpenPrice, StringFormat={}{0:F5}}" Width="105" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Current Price" Binding="{Binding CurrentPrice, StringFormat={}{0:F5}}" Width="105" ElementStyle="{StaticResource NteTradingDataFont}"/>

                        <!-- Conditionally Colored Profit Column utilizing the ProfitToBrushConverter -->
                        <DataGridTextColumn Header="Profit" Binding="{Binding Profit, StringFormat={}{0:C2}}" Width="105">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                    <Setter Property="Foreground" Value="{Binding Profit, Converter={StaticResource ProfitToBrushConverter}}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Swap" Binding="{Binding Swap, StringFormat={}{0:C2}}" Width="85" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Comm" Binding="{Binding Commission, StringFormat={}{0:C2}}" Width="85" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Open Time" Binding="{Binding OpenTime, StringFormat='HH:mm:ss'}" Width="105" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="85"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Actions (shifted to Grid.Row 6) -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Refresh Positions (Left-aligned) -->
                        <ColumnDefinition Width="*"/>
                        <!-- Divider Spacer -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Operational Actions (Right-aligned) -->
                    </Grid.ColumnDefinitions>

                    <!-- Manual Grid Refresh -->
                    <Button Grid.Column="0" Content="REFRESH POSITIONS" Command="{Binding RefreshPositionsCommand}" Style="{StaticResource NteSecondaryButton}" Height="38"/>

                    <!-- Operational Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- Batch Close Profits Button (Emerald Green Theme) -->
                        <Button Content="CLOSE ALL PROFITS" Command="{Binding CloseAllProfitsCommand}" Height="38" Margin="0,0,10,0" Padding="15,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource LightSuccessBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource LightSuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Batch Close Losses Button (Coral Orange Theme) -->
                        <Button Content="CLOSE ALL LOSSES" Command="{Binding CloseAllLossesCommand}" Height="38" Margin="0,0,10,0" Padding="15,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                    <Setter Property="Background" Value="#FFA726"/>
                                    <Setter Property="BorderBrush" Value="#FFA726"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Background" Value="#FFB74D"/>
                                            <Setter Property="BorderBrush" Value="#FFB74D"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Close Selected Single Target Position Button (Muted Neutral Theme) -->
                        <Button Content="CLOSE SELECTED" Command="{Binding CloseCommand}" Height="38" Margin="0,0,10,0" Padding="15,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource LightSurfaceVariantBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource LightGlassBorderBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource LightTextPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Emergency Close All Positions Button (Solid Ruby Red Theme) -->
                        <Button Content="CLOSE ALL POSITIONS" Command="{Binding CloseAllCommand}" Height="38" Padding="15,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                    <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource LightErrorBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource LightErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>