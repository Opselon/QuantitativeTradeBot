<UserControl x:Class="Nexus.Desktop.Views.Mt5TradingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nexus.Desktop.Views"
             xmlns:vm="clr-namespace:Nexus.Desktop.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 1. Connection Monitoring -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <!-- 2. Manual Order Entry (Redesigned Buy/Sell ticket) -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <!-- 3. Active Positions -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. Connection Monitoring widgets -->
        <materialDesign:Card Grid.Row="0" Style="{StaticResource NtePremiumCard}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Current Mode -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="GATEWAY PROFILE" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CurrentMode, FallbackValue='Simulation'}" Foreground="{DynamicResource PrimaryBrush}" FontSize="15" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource LightPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Connection State with Pulsing / Glow Indicator -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="BRIDGE STATE" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True"/>
                                                <Condition Binding="{Binding IsConnected}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Fill" Value="{DynamicResource LightErrorBrush}"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True"/>
                                                <Condition Binding="{Binding IsConnected}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Fill" Value="{DynamicResource LightSuccessBrush}"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatusText, FallbackValue='Disconnected'}" Style="{StaticResource NteBodyLarge}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Bridge Active status -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="SOCKET LISTEN" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <TextBlock Text="Listening / Active" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NteBodyLarge}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                        <Setter Property="Text" Value="Inactive"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True"/>
                                            <Condition Binding="{Binding IsConnected}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource LightTextSecondaryBrush}"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Last response -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="ROUND TRIP LATENCY" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding LastResponseTimeText, FallbackValue='0 ms'}" Style="{StaticResource NteTradingDataFont}" FontWeight="Bold"/>
                </StackPanel>

                <!-- Refresh rate -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="LAST SYNCED TIME" Style="{StaticResource NteLabelSmall}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding LastSuccessfulRefreshText, FallbackValue='Never'}" Style="{StaticResource NteBodyLarge}"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- 2. Manual Order Entry (Emerald and Coral material themed Buy/Sell ticket) -->
        <materialDesign:Card Grid.Row="2" Style="{StaticResource NtePremiumCard}">
            <StackPanel>
                <TextBlock Text="MANUAL ORDER TICK ENTRY" Style="{StaticResource NteTitleLarge}" Margin="0,0,0,20"/>

                <Grid Margin="10,0,10,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Instrument Symbol input -->
                    <TextBox Grid.Column="0" Text="{Binding SelectedSymbol, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}" materialDesign:HintAssist.Hint="Trading Instrument Symbol (e.g. EURUSD)"/>

                    <!-- Order volume lots input -->
                    <TextBox Grid.Column="2" Text="{Binding OrderVolume, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}" materialDesign:HintAssist.Hint="Trade Position Volume Lots (e.g. 0.10)"/>

                    <!-- BUY Market order control -->
                    <Button Grid.Column="4" Content="BUY MARKET" Command="{Binding BuyCommand}" Height="42" Padding="25,0" AutomationProperties.Name="BuyButton">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource LightSuccessBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource LightSuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- SELL Market order control -->
                    <Button Grid.Column="6" Content="SELL MARKET" Command="{Binding SellCommand}" Height="42" Padding="25,0" AutomationProperties.Name="SellButton">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource LightErrorBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource LightErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Feedback messaging -->
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" FontWeight="Bold" FontSize="13" Margin="0,0,20,0" VerticalAlignment="Center" Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource WarningBrush}" FontSize="13" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightWarningBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1" Content="CLEAR ERRORS" Command="{Binding ClearErrorCommand}" Style="{StaticResource NteSecondaryButton}" Height="30" Padding="12,0" FontSize="11" Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"/>
                </Grid>
            </StackPanel>
        </materialDesign:Card>

        <!-- 3. Active positions grid -->
        <materialDesign:Card Grid.Row="4" Style="{StaticResource NtePremiumCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ACTIVE TERMINAL POSITIONS" Style="{StaticResource NteTitleLarge}"/>

                <!-- Modern Datagrid for Positions -->
                <DataGrid Grid.Row="2" ItemsSource="{Binding OpenPositions}" SelectedItem="{Binding SelectedPosition}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" BorderBrush="{DynamicResource GlassBorderBrush}" Background="{DynamicResource BackgroundBrush}" RowBackground="{DynamicResource SurfaceContainerBrush}" AlternatingRowBackground="{DynamicResource SurfaceBrush}">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LightGlassBorderBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource LightGlassBorderBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}"/>
                                    <Setter Property="RowBackground" Value="{DynamicResource LightSurfaceContainerBrush}"/>
                                    <Setter Property="AlternatingRowBackground" Value="{DynamicResource LightSurfaceBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontFamily" Value="Segoe UI Variable, Inter"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource LightSurfaceVariantBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource LightTextSecondaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="FontFamily" Value="Segoe UI Variable, Inter"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource LightTextPrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ticket" Binding="{Binding Ticket}" Width="85" FontWeight="SemiBold" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="85" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="75"/>
                        <DataGridTextColumn Header="Volume" Binding="{Binding Volume, StringFormat={}{0:F2}}" Width="85" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Open Price" Binding="{Binding OpenPrice, StringFormat={}{0:F5}}" Width="105" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Current Price" Binding="{Binding CurrentPrice, StringFormat={}{0:F5}}" Width="105" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Profit" Binding="{Binding Profit, StringFormat={}{0:C2}}" Width="105">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource NteTradingDataFont}">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource LightSuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Swap" Binding="{Binding Swap, StringFormat={}{0:C2}}" Width="85" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Comm" Binding="{Binding Commission, StringFormat={}{0:C2}}" Width="85" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Open Time" Binding="{Binding OpenTime, StringFormat='HH:mm:ss'}" Width="105" ElementStyle="{StaticResource NteTradingDataFont}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="85"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Actions -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="REFRESH POSITIONS" Command="{Binding RefreshPositionsCommand}" Style="{StaticResource NteSecondaryButton}" Margin="0,0,10,0"/>
                    <Button Content="CLOSE POSITION" Command="{Binding CloseCommand}" Height="38" Padding="20,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource LightErrorBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource LightErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
