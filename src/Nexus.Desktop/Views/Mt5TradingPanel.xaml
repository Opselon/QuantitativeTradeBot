<UserControl x:Class="Nexus.Desktop.Views.Mt5TradingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nexus.Desktop.Views"
             xmlns:vm="clr-namespace:Nexus.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- Panel Cards style -->
        <Style x:Key="TradingPanelCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderTranslucentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{DynamicResource ShadowBrush}" BlurRadius="12" Direction="270" ShadowDepth="2" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <!-- 1. Top Connection Panel -->
            <RowDefinition Height="Auto"/>
            <!-- 2. Middle Trade Entry Panel -->
            <RowDefinition Height="Auto"/>
            <!-- 3. Bottom Positions Grid -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- 1. CONNECTION PANEL                         -->
        <!-- ========================================== -->
        <Border Grid.Row="0" Style="{StaticResource TradingPanelCard}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Current Mode -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="CURRENT MODE" Style="{StaticResource EnterpriseLabel}"/>
                    <TextBlock Text="{Binding CurrentMode, FallbackValue='Simulation'}" Foreground="{DynamicResource AccentBrush}" FontSize="15" FontWeight="Bold" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Connection State -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="CONNECTION STATE" Style="{StaticResource EnterpriseLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" x:Name="PulseTransform"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.4" Duration="0:0:0.8"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.4" Duration="0:0:0.8"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.8"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatusText, FallbackValue='Disconnected'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Bridge Status -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="BRIDGE STATUS" Style="{StaticResource EnterpriseLabel}"/>
                    <TextBlock Text="Listening / Active" FontSize="13" Margin="0,6,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                        <Setter Property="Text" Value="Inactive"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="FontWeight" Value="Normal"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Last Response Time -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="LAST RESPONSE TIME" Style="{StaticResource EnterpriseLabel}"/>
                    <TextBlock Text="{Binding LastResponseTimeText, FallbackValue='0 ms'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,6,0,0" FontFamily="Consolas"/>
                </StackPanel>

                <!-- Last Successful Refresh -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="LAST REFRESH" Style="{StaticResource EnterpriseLabel}"/>
                    <TextBlock Text="{Binding LastSuccessfulRefreshText, FallbackValue='Never'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========================================== -->
        <!-- 2. TRADE ENTRY PANEL                       -->
        <!-- ========================================== -->
        <Border Grid.Row="1" Style="{StaticResource TradingPanelCard}" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="MANUAL ORDER TICK ENTRY" Style="{StaticResource EnterpriseSubHeader}" Foreground="{DynamicResource AccentBrush}"/>

                <Grid Grid.Row="1" Margin="0,8,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Symbol -->
                    <TextBlock Grid.Column="0" Text="Symbol:" Style="{StaticResource EnterpriseLabel}"/>
                    <TextBox Grid.Column="1" Text="{Binding SelectedSymbol, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}"/>

                    <!-- Volume -->
                    <TextBlock Grid.Column="3" Text="Volume:" Style="{StaticResource EnterpriseLabel}"/>
                    <TextBox Grid.Column="4" Text="{Binding OrderVolume, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}"/>

                    <!-- Buttons with exact AutomationProperties.Name -->
                    <Button Grid.Column="6" Content="BUY MARKET" Command="{Binding BuyCommand}" Style="{DynamicResource BuyBtn}" AutomationProperties.Name="BuyButton"/>
                    <Button Grid.Column="8" Content="SELL MARKET" Command="{Binding SellCommand}" Style="{DynamicResource SellBtn}" AutomationProperties.Name="SellButton"/>
                </Grid>

                <!-- Status & Validation Messaging -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Feedback / Validation / Errors -->
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" FontSize="12" Margin="0,0,16,0" VerticalAlignment="Center" Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource WarningBrush}" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="Clear Error" Command="{Binding ClearErrorCommand}" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="12,5" Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ========================================== -->
        <!-- 3. OPEN POSITIONS GRID                     -->
        <!-- ========================================== -->
        <Border Grid.Row="2" Style="{StaticResource TradingPanelCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ACTIVE TERMINAL POSITIONS" Style="{StaticResource EnterpriseSubHeader}" Foreground="{DynamicResource AccentBrush}"/>

                <DataGrid Grid.Row="2" ItemsSource="{Binding OpenPositions}" SelectedItem="{Binding SelectedPosition}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ticket" Binding="{Binding Ticket}" Width="75">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="75"/>
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="65">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Side}" Value="Buy">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Side}" Value="Sell">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Volume" Binding="{Binding Volume, StringFormat={}{0:F2}}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Open Price" Binding="{Binding OpenPrice, StringFormat={}{0:F5}}" Width="95">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Current Price" Binding="{Binding CurrentPrice, StringFormat={}{0:F5}}" Width="95">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Profit" Binding="{Binding Profit, StringFormat={}{0:C2}}" Width="85">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Swap" Binding="{Binding Swap, StringFormat={}{0:C2}}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Comm" Binding="{Binding Commission, StringFormat={}{0:C2}}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Open Time" Binding="{Binding OpenTime, StringFormat='HH:mm:ss'}" Width="85">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="75"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="REFRESH POSITIONS" Command="{Binding RefreshPositionsCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                    <Button Content="CLOSE POSITION" Command="{Binding CloseCommand}" Style="{DynamicResource SellBtn}" Padding="20,8"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
