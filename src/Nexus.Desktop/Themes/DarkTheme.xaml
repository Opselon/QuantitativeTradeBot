<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- Base Dark Brushes (Deep Space Enterprise) -->
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#0A0B0E" po:Freeze="True"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#12151B" po:Freeze="True"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#12151B" po:Freeze="True"/>
    <SolidColorBrush x:Key="InteractiveBrush" Color="#1C202B" po:Freeze="True"/>

    <!-- Accent & Status Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="#00E5FF" po:Freeze="True"/> <!-- Cyan accent -->
    <SolidColorBrush x:Key="AccentIndigoBrush" Color="#6366F1" po:Freeze="True"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" po:Freeze="True"/> <!-- Emerald success -->
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" po:Freeze="True"/> <!-- Red danger -->
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" po:Freeze="True"/> <!-- Orange warning -->

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" po:Freeze="True"/>

    <!-- UI Element Brushes -->
    <SolidColorBrush x:Key="BorderBrush" Color="#1E293B" po:Freeze="True"/>
    <SolidColorBrush x:Key="BorderTranslucentBrush" Color="#FFFFFF" Opacity="0.08" po:Freeze="True"/>
    <SolidColorBrush x:Key="ShadowBrush" Color="#000000" po:Freeze="True"/>

</ResourceDictionary>
