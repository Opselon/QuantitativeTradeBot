<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Base Palette (Prefixed) -->
    <SolidColorBrush x:Key="LightPrimaryBackgroundBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="LightSecondaryBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="LightCardBackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="LightInteractiveBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="LightAccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="LightAccentIndigoBrush" Color="#4F46E5"/>
    <SolidColorBrush x:Key="LightSuccessBrush" Color="#059669"/>
    <SolidColorBrush x:Key="LightDangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="LightWarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="LightTextPrimaryBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="LightTextSecondaryBrush" Color="#475569"/>
    <SolidColorBrush x:Key="LightBorderBrush" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="LightBorderTranslucentBrush" Color="#12000000"/>
    <Color x:Key="LightShadowBrush">#64748B</Color>

</ResourceDictionary>
