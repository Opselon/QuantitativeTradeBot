<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- Base Light Brushes (Modern Corporate) -->
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#F1F5F9" po:Freeze="True"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="InteractiveBrush" Color="#E2E8F0" po:Freeze="True"/>

    <!-- Accent & Status Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" po:Freeze="True"/> <!-- Royal Blue -->
    <SolidColorBrush x:Key="AccentIndigoBrush" Color="#334155" po:Freeze="True"/> <!-- Slate -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#059669" po:Freeze="True"/> <!-- Forest -->
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" po:Freeze="True"/> <!-- Red danger -->
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706" po:Freeze="True"/> <!-- Orange warning -->

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569" po:Freeze="True"/>

    <!-- UI Element Brushes -->
    <SolidColorBrush x:Key="BorderBrush" Color="#CBD5E1" po:Freeze="True"/>
    <SolidColorBrush x:Key="BorderTranslucentBrush" Color="#000000" Opacity="0.08" po:Freeze="True"/>
    <SolidColorBrush x:Key="ShadowBrush" Color="#64748B" po:Freeze="True"/>

</ResourceDictionary>
