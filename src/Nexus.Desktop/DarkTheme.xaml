<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Brushes -->
    <Color x:Key="PrimaryColor">#00E5FF</Color>
    <Color x:Key="PrimaryContainerColor">#004F58</Color>
    <Color x:Key="SurfaceColor">#080B12</Color>
    <Color x:Key="SurfaceContainerColor">#111827</Color>
    <Color x:Key="SurfaceVariantColor">#1F2937</Color>
    <Color x:Key="BackgroundColor">#05070B</Color>
    <Color x:Key="TextPrimaryColor">#E5E7EB</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{StaticResource PrimaryContainerColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource SurfaceContainerColor}"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceVariantColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

    <SolidColorBrush x:Key="GlassBorderBrush" Color="#393E46" Opacity="0.5"/>
</ResourceDictionary>
