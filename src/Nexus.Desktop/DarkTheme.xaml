<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Accent -->
    <Color x:Key="PrimaryColor">#22D3EE</Color>

    <!-- Primary Hover -->
    <Color x:Key="PrimaryHoverColor">#67E8F9</Color>

    <!-- Primary Pressed -->
    <Color x:Key="PrimaryPressedColor">#06B6D4</Color>

    <!-- Secondary Accent -->
    <Color x:Key="SecondaryColor">#A855F7</Color>

    <!-- Success -->
    <Color x:Key="SuccessColor">#22C55E</Color>

    <!-- Warning -->
    <Color x:Key="WarningColor">#F59E0B</Color>

    <!-- Error -->
    <Color x:Key="ErrorColor">#EF4444</Color>

    <!-- Info -->
    <Color x:Key="InfoColor">#3B82F6</Color>

    <!-- ========================= -->
    <!-- BACKGROUND SYSTEM         -->
    <!-- ========================= -->

    <!-- Window -->
    <Color x:Key="BackgroundColor">#090B11</Color>

    <!-- Main Panels -->
    <Color x:Key="SurfaceColor">#111827</Color>

    <!-- Cards -->
    <Color x:Key="SurfaceContainerColor">#1A2234</Color>

    <!-- Elevated Cards -->
    <Color x:Key="SurfaceContainerHighColor">#232D42</Color>

    <!-- Hover -->
    <Color x:Key="SurfaceHoverColor">#2E3A52</Color>

    <!-- Selected -->
    <Color x:Key="SurfaceSelectedColor">#13354A</Color>

    <!-- Input -->
    <Color x:Key="InputBackgroundColor">#151D2D</Color>

    <!-- Popup -->
    <Color x:Key="PopupBackgroundColor">#1C2435</Color>

    <!-- ========================= -->
    <!-- TYPOGRAPHY                -->
    <!-- ========================= -->

    <!-- Main Text -->
    <Color x:Key="TextPrimaryColor">#F8FAFC</Color>

    <!-- Secondary -->
    <Color x:Key="TextSecondaryColor">#CBD5E1</Color>

    <!-- Tertiary -->
    <Color x:Key="TextTertiaryColor">#94A3B8</Color>

    <!-- Disabled -->
    <Color x:Key="TextDisabledColor">#64748B</Color>

    <!-- Placeholder -->
    <Color x:Key="PlaceholderColor">#7C8BA1</Color>

    <!-- ========================= -->
    <!-- BORDERS                   -->
    <!-- ========================= -->

    <Color x:Key="BorderColor">#334155</Color>

    <Color x:Key="BorderLightColor">#475569</Color>

    <Color x:Key="DividerColor">#293548</Color>

    <!-- ========================= -->
    <!-- SHADOWS / GLASS           -->
    <!-- ========================= -->

    <Color x:Key="GlassColor">#2A3A54</Color>

    <!-- ============================================================= -->
    <!-- BRUSHES                                                       -->
    <!-- ============================================================= -->

    <!-- Accent -->

    <SolidColorBrush x:Key="PrimaryBrush"
                     Color="{StaticResource PrimaryColor}"/>

    <SolidColorBrush x:Key="PrimaryHoverBrush"
                     Color="{StaticResource PrimaryHoverColor}"/>

    <SolidColorBrush x:Key="PrimaryPressedBrush"
                     Color="{StaticResource PrimaryPressedColor}"/>

    <SolidColorBrush x:Key="SecondaryBrush"
                     Color="{StaticResource SecondaryColor}"/>

    <!-- Background -->

    <SolidColorBrush x:Key="BackgroundBrush"
                     Color="{StaticResource BackgroundColor}"/>

    <SolidColorBrush x:Key="SurfaceBrush"
                     Color="{StaticResource SurfaceColor}"/>

    <SolidColorBrush x:Key="SurfaceContainerBrush"
                     Color="{StaticResource SurfaceContainerColor}"/>

    <SolidColorBrush x:Key="SurfaceContainerHighBrush"
                     Color="{StaticResource SurfaceContainerHighColor}"/>

    <SolidColorBrush x:Key="SurfaceHoverBrush"
                     Color="{StaticResource SurfaceHoverColor}"/>

    <SolidColorBrush x:Key="SurfaceSelectedBrush"
                     Color="{StaticResource SurfaceSelectedColor}"/>

    <SolidColorBrush x:Key="InputBackgroundBrush"
                     Color="{StaticResource InputBackgroundColor}"/>

    <SolidColorBrush x:Key="PopupBackgroundBrush"
                     Color="{StaticResource PopupBackgroundColor}"/>

    <!-- Typography -->

    <SolidColorBrush x:Key="TextPrimaryBrush"
                     Color="{StaticResource TextPrimaryColor}"/>

    <SolidColorBrush x:Key="TextSecondaryBrush"
                     Color="{StaticResource TextSecondaryColor}"/>

    <SolidColorBrush x:Key="TextTertiaryBrush"
                     Color="{StaticResource TextTertiaryColor}"/>

    <SolidColorBrush x:Key="TextDisabledBrush"
                     Color="{StaticResource TextDisabledColor}"/>

    <SolidColorBrush x:Key="PlaceholderBrush"
                     Color="{StaticResource PlaceholderColor}"/>

    <!-- Status -->

    <SolidColorBrush x:Key="SuccessBrush"
                     Color="{StaticResource SuccessColor}"/>

    <SolidColorBrush x:Key="WarningBrush"
                     Color="{StaticResource WarningColor}"/>

    <SolidColorBrush x:Key="ErrorBrush"
                     Color="{StaticResource ErrorColor}"/>

    <SolidColorBrush x:Key="InfoBrush"
                     Color="{StaticResource InfoColor}"/>

    <!-- Borders -->

    <SolidColorBrush x:Key="BorderBrush"
                     Color="{StaticResource BorderColor}"/>

    <SolidColorBrush x:Key="BorderLightBrush"
                     Color="{StaticResource BorderLightColor}"/>

    <SolidColorBrush x:Key="DividerBrush"
                     Color="{StaticResource DividerColor}"/>

    <!-- Glass -->

    <SolidColorBrush x:Key="GlassBorderBrush"
                     Color="{StaticResource GlassColor}"
                     Opacity="0.45"/>

    <!-- ============================================================= -->
    <!-- GLOBAL TYPOGRAPHY                                              -->
    <!-- ============================================================= -->

    <Style TargetType="TextBlock">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background"
                Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush"
                Value="{StaticResource BorderBrush}"/>
        <Setter Property="CaretBrush"
                Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="SelectionBrush"
                Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background"
                Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush"
                Value="{StaticResource BorderBrush}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background"
                Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush"
                Value="{StaticResource BorderBrush}"/>
    </Style>

</ResourceDictionary>
