<Window x:Class="Nexus.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Nexus.Desktop.Converters"
        xmlns:views="clr-namespace:Nexus.Desktop.Views"
        Title="{Binding AppVersion, StringFormat='Nexus Trading Engine - Desktop Workstation v{0}'}"
        Height="820" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:EqualityToBooleanConverter x:Key="EqualityToBooleanConverter"/>

        <!-- Glass Card Style -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderTranslucentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{DynamicResource ShadowBrush}" BlurRadius="12" Direction="270" ShadowDepth="2" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Database Choice Card with Scale Hover Animation -->
        <Style x:Key="DatabaseChoiceCard" TargetType="Border" BasedOn="{StaticResource GlassCard}">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.00" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.00" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Rounded Active/Inactive Navigation Button Styles -->
        <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

    </Window.Resources>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, ElementName=ThemeToggle}" Value="True">
                    <Setter Property="Resources">
                        <Setter.Value>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="Themes/LightTheme.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                            </ResourceDictionary>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 1. Top Status Bar / Header -->
            <RowDefinition Height="Auto"/>
            <!-- 2. Main Workspace/Wizard Work Area -->
            <RowDefinition Height="*"/>
            <!-- 3. Bottom Diagnostics & Structured Log Panel -->
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- =================================================================== -->
        <!-- TOP STATUS BAR / Badge Bar                                          -->
        <!-- =================================================================== -->
        <Border Grid.Row="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderTranslucentBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Application Brand Logo with Modern Space Typography -->
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Path Data="M12,2 L22,8 L22,16 L12,22 L2,16 L2,8 Z M12,4 L4,9 L4,15 L12,20 L20,15 L20,9 Z" Fill="{DynamicResource AccentBrush}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="N E X U S" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="T R A D I N G   E N G I N E" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Segoe UI" FontSize="11" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: Theme Switch + Status Badges -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                    <!-- Dynamic Theme Toggle Switch -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="LIGHT MODE" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <CheckBox x:Name="ThemeToggle" Style="{StaticResource ThemeToggleStyle}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Environment Badge -->
                    <Border Background="{DynamicResource DangerBrush}" CornerRadius="10" Padding="10,4" Margin="0,0,10,0">
                        <TextBlock Text="DEVELOPMENT / SIMULATION" Foreground="White" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <!-- Connection Status Badge -->
                    <Border CornerRadius="10" Padding="10,4" Margin="0,0,10,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="SIMULATOR ACTIVE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                                <Setter Property="Text" Value="REAL MT5 BRIDGE ACTIVE"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- Chosen Provider Badge -->
                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="10" Padding="10,4">
                        <TextBlock Text="{Binding SelectedProvider}" Foreground="#0A0B0E" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =================================================================== -->
        <!-- MAIN WORKSPACE                                                      -->
        <!-- =================================================================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left Navigation Bar -->
                <ColumnDefinition Width="200"/>
                <!-- Central Panel Workspace -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT NAVIGATION PANEL -->
            <Border Grid.Column="0" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderTranslucentBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="12,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Navigation Items -->
                    <StackPanel Grid.Row="0">
                        <!-- Navigation Item Header -->
                        <TextBlock Text="TERMINAL WORKSPACES" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold" Margin="8,0,0,12"/>

                        <!-- Onboarding Menu Link (Active during onboarding) -->
                        <Button Content="Onboarding Wizard">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="#0A0B0E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOnboarded}" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Dashboard Menu Link -->
                        <Button Content="Dashboard" Command="{Binding SelectDashboardCommand}" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="MT5 Bridge" Command="{Binding SelectMt5BridgeCommand}" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Market Watch" Command="{Binding SelectMarketWatchCommand}" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Manual Desk" Command="{Binding SelectManualDeskCommand}" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Account Metrics" Command="{Binding SelectAccountMetricsCommand}" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="4">
                                            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Native Engine" Command="{Binding SelectNativeEngineCommand}" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="5">
                                            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Diagnostics" Command="{Binding SelectDiagnosticsCommand}" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="6">
                                            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Settings" Command="{Binding SelectSettingsCommand}" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="7">
                                            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Test Console" Command="{Binding SelectTestConsoleCommand}" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="8">
                                            <Setter Property="Background" Value="{DynamicResource InteractiveBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Footer Details -->
                    <StackPanel Grid.Row="1" Margin="8,0">
                        <TextBlock Text="NEXUS CLIENT READY" Foreground="{DynamicResource SuccessBrush}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding AppVersion, StringFormat='NTE CORE v{0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="9" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CENTRAL WORKSPACE PANEL -->
            <Border Grid.Column="1" Background="{DynamicResource PrimaryBackgroundBrush}" Padding="24">
                <Grid>
                    <!-- =============================================================== -->
                    <!-- ONBOARDING WIZARD SCREENS                                       -->
                    <!-- =============================================================== -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnboarded}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Wizard Progress Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="{Binding CurrentStep, StringFormat='ONBOARDING WIZARD - STEP {0} OF 6'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold"/>
                            <ProgressBar Value="{Binding CurrentStep}" Minimum="1" Maximum="6" Height="6" Margin="0,8,0,0" Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource InteractiveBrush}"/>
                        </StackPanel>

                        <!-- Wizard Main Content Area (Glassmorphism styled content card) -->
                        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="32">
                            <Grid>
                                <!-- STEP 1: Select Persistence Provider -->
                                <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Select Local Database Persistence Mode" Style="{StaticResource EnterpriseHeader}"/>
                                    <TextBlock Text="Choose how Nexus stores account credentials, trades, positions, and strategy configuration profiles." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,24"/>

                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Option A: PostgreSQL (Recommended) -->
                                        <Border Grid.Column="0" Style="{StaticResource DatabaseChoiceCard}" Padding="24,20">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <RadioButton IsChecked="{Binding SelectedProvider, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=PostgreSQL}" GroupName="Provider" Content="PostgreSQL Server" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <Border Background="{DynamicResource SuccessBrush}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="RECOMMENDED" Foreground="White" FontSize="8" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="• Production grade reliability and scalability." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,4"/>
                                                <TextBlock Text="• Supports high-throughput raw Binary COPY partitioning." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,4"/>
                                                <TextBlock Text="• Retains history across simulated system restarts." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,4"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Option B: SQLite (Quick Start) -->
                                        <Border Grid.Column="2" Style="{StaticResource DatabaseChoiceCard}" Padding="24,20">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <RadioButton IsChecked="{Binding SelectedProvider, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=SQLite}" GroupName="Provider" Content="SQLite" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <Border Background="{DynamicResource InteractiveBrush}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="QUICK START" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="8" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="• Local self-contained file database." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,4"/>
                                                <TextBlock Text="• Zero configuration or system requirements." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,4"/>
                                                <TextBlock Text="• Perfect for local evaluation, UI exploration, and debugging." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,4"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="PostgreSQL is recommended for production enterprise environments. Ensure your database server is running." Foreground="{DynamicResource WarningBrush}" FontSize="11" Margin="0,5,0,0" FontWeight="SemiBold"/>
                                </StackPanel>

                                <!-- STEP 2: Configure & Initialize Database -->
                                <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Initialize Selected Persistence Path" Style="{StaticResource EnterpriseHeader}"/>
                                    <TextBlock Text="Verify and prepare the tables, indexes, and database schemas required for algorithmic execution." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,24"/>

                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="16"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Connection String:" Style="{StaticResource EnterpriseLabel}"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Status Indicator:" Style="{StaticResource EnterpriseLabel}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DatabaseStatus}" Foreground="{DynamicResource AccentBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Initialize Database" Command="{Binding InitializeDbCommand}" Style="{StaticResource ActionButton}" Margin="0,0,12,0"/>
                                        <Button Content="Apply Migrations" Command="{Binding MigrateDbCommand}" Style="{StaticResource SecondaryButton}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- STEP 3: Create MT5 Connection Profile -->
                                <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="MetaTrader 5 Onboarding Credentials" Style="{StaticResource EnterpriseHeader}"/>
                                    <TextBlock Text="Configure connection details to route orders and download snapshots. Sensitive passwords are saved securely using ISecretStore." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,16"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Profile Name & Server -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile Name:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Server / Broker:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding BrokerServer, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <!-- Row 1: Login & Password -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Login / Account ID:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LoginAccountId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Password (Masked):" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <!-- Row 2: Terminal Path -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="MT5 Terminal Path:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding TerminalPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <!-- Row 3: Timeout & Reconnect -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Timeout (Seconds):" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <TextBlock Grid.Row="3" Grid.Column="3" Text="Auto Reconnect:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <CheckBox Grid.Row="3" Grid.Column="4" IsChecked="{Binding AutoReconnect}" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,0,12"/>

                                        <!-- Row 4: Mode Selection (Simulated vs Real Bridge) -->
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="MT5 Bridge Mode:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                                            <RadioButton Content="Simulated MT5" IsChecked="{Binding Mt5Mode, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=Simulated}" Foreground="{DynamicResource TextPrimaryBrush}" GroupName="Mt5ModeGroup" Margin="0,0,20,0"/>
                                            <RadioButton Content="Real MT5 Bridge" IsChecked="{Binding Mt5Mode, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=Real}" Foreground="{DynamicResource TextPrimaryBrush}" GroupName="Mt5ModeGroup"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Conditional Real Bridge Configuration Fields -->
                                    <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderTranslucentBrush}" BorderThickness="1" Padding="20" CornerRadius="8" Margin="0,16,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="REAL BRIDGE ENDPOINT CONFIGURATION" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

