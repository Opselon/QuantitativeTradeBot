                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Button Content="Launch Professional Workspace" Command="{Binding LaunchWorkspaceCmd}" Style="{StaticResource ActionButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Wizard Footer Navigation Buttons -->
                        <DockPanel Grid.Row="3" Margin="0,20,0,0">
                            <Button Content="Back" Command="{Binding BackCommand}" Style="{StaticResource SecondaryButton}" DockPanel.Dock="Left"/>

                            <!-- Custom Next button logic per step -->
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button Content="Next Step" Command="{Binding SelectProviderNextCommand}" Style="{StaticResource ActionButton}" Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="Next Step" Command="{Binding DbNextCommand}" Style="{StaticResource ActionButton}" Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="Next Step" Command="{Binding CreateProfileNextCommand}" Style="{StaticResource ActionButton}" Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="Next Step" Command="{Binding TestNextCommand}" Style="{StaticResource ActionButton}" Visibility="{Binding IsStep4, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="Next Step" Command="{Binding AccountNextCommand}" Style="{StaticResource ActionButton}" Visibility="{Binding IsStep5, Converter={StaticResource BoolToVisConverter}}"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>

                    <!-- =============================================================== -->
                    <!-- WORKSPACE TRADING DASHBOARD PANEL (Visible after onboarding)    -->
                    <!-- =============================================================== -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnboarded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="QUANT ALGORITHMIC DESK" Style="{StaticResource EnterpriseHeader}"/>
                        <TextBlock Grid.Row="1" Text="Live algorithmic system monitoring dashboard panel. Real-time market ingestion and native C++ indicator engines active." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,15"/>

                        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </TabControl.Resources>

                            <!-- Tab 0: Dashboard (General Welcome and Quick Stats) -->
