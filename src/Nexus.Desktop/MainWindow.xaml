                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Broker Server:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.BrokerServer}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Account Mode:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.AccountMode}" Foreground="{DynamicResource AccentBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Right side metrics -->
                                            <StackPanel Grid.Column="2">
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Live Account Balance:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Balance, StringFormat={}{0:C2}}" Foreground="{DynamicResource SuccessBrush}" FontSize="16" FontWeight="Bold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Live Equity value:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Equity, StringFormat={}{0:C2}}" Foreground="{DynamicResource SuccessBrush}" FontSize="16" FontWeight="Bold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Free Margin:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.FreeMargin, StringFormat={}{0:C2}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <Button Content="REFRESH METRICS" Command="{Binding BridgeRefreshAccountCommand}" Style="{StaticResource ActionButton}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                            </TabItem>

                            <!-- Tab 5: Native Engine / Intel -->
                            <TabItem>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="400"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Panel: Native core telemetry details -->
                                    <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="24">
                                        <StackPanel>
                                            <TextBlock Text="NATIVE ACCELERATION PERFORMANCE DIAGNOSTICS" Style="{StaticResource EnterpriseHeader}"/>

                                            <Grid Margin="0,20,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Total Processed Ticks:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ProcessedTickCount}" Foreground="{DynamicResource SuccessBrush}" FontSize="15" FontWeight="Bold" FontFamily="Consolas"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Last Processed Symbol:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastProcessedSymbol}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Processing Latency:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastProcessingLatencyMs, StringFormat={}{0:F4} ms}" Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" FontFamily="Consolas"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Last update timestamp:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastProcessedTimestampText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="Consolas"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Right Panel: The Neural view -->
                                    <views:NexusIntelligenceDashboard Grid.Column="2" DataContext="{Binding Intelligence}"/>
                                </Grid>
                            </TabItem>

                            <!-- Tab 6: Diagnostics -->
                            <TabItem>
                                <Border Style="{StaticResource GlassCard}" Padding="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="SYSTEM DIAGNOSTICS &amp; BOUNDED LOGS" Style="{StaticResource EnterpriseHeader}"/>
                                        <!-- Displays recent log entries directly in-view -->
                                        <ListView Grid.Row="1" ItemsSource="{Binding DiagnosticService.Logs}" Margin="0,12,0,0">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Timestamp" DisplayMemberBinding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" Width="120"/>
                                                    <GridViewColumn Header="Subsystem" DisplayMemberBinding="{Binding Subsystem}" Width="110"/>
                                                    <GridViewColumn Header="Level" DisplayMemberBinding="{Binding Level}" Width="70"/>
                                                    <GridViewColumn Header="Diagnostic Message" DisplayMemberBinding="{Binding Message}" Width="520"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <!-- Tab 7: Settings -->
                            <TabItem>
                                <Border Style="{StaticResource GlassCard}" Padding="24">
                                    <StackPanel>
                                        <TextBlock Text="NEXUS TRADING PLATFORM CONFIGURATION" Style="{StaticResource EnterpriseHeader}"/>
                                        <TextBlock Text="Manage local database options and general application settings." Style="{StaticResource EnterpriseBodyText}" Margin="0,6,0,24"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Active Database Provider:" Style="{StaticResource EnterpriseLabel}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedProvider}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </TabItem>

                            <!-- Tab 8: Test Console & Real Smoke Test Workflow -->
                            <TabItem>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left side: Run Smoke Test Controls -->
                                    <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="24">
                                        <StackPanel>
                                            <TextBlock Text="REAL LOCALHOST BRIDGE PIPELINE VERIFIER" Style="{StaticResource EnterpriseHeader}"/>
                                            <TextBlock Text="Press the button below to run an automated, live integration smoke test that connects, authenticates, pings, subscribes, monitors EURUSD ticks, and disconnects cleanly." Style="{StaticResource EnterpriseBodyText}" Margin="0,6,0,20"/>

                                            <Button Content="RUN AUTOMATED REAL SMOKE TEST" Command="{Binding RunSmokeTestCommand}" Style="{StaticResource ActionButton}" Padding="24,14" FontSize="13" HorizontalAlignment="Left" Margin="0,0,0,20"/>

                                            <Border BorderBrush="{DynamicResource BorderTranslucentBrush}" BorderThickness="0,1,0,0" Margin="0,4,0,20"/>

                                            <TextBlock Text="LIGHTWEIGHT DIAGNOSTICS API" Style="{StaticResource EnterpriseSubHeader}" Margin="0,0,0,12"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Connection Status:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BridgeConnectionStatusText}" Foreground="{DynamicResource AccentBrush}" FontSize="13" FontWeight="Bold"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Auth Status:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding IsBridgeAuthenticated}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Ping Latency:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BridgePingLatencyMs, StringFormat={}{0:F2} ms}" Foreground="{DynamicResource WarningBrush}" FontSize="12" FontFamily="Consolas" FontWeight="Bold"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Total Ticks Ingested:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ProcessedTickCount}" Foreground="{DynamicResource SuccessBrush}" FontSize="12" FontFamily="Consolas" FontWeight="Bold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Right side: Real-time progress logs -->
                                    <Border Grid.Column="2" Style="{StaticResource GlassCard}" Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="SMOKE TEST CONFLOW LOG" Style="{StaticResource EnterpriseHeader}"/>
                                            <ListView Grid.Row="1" ItemsSource="{Binding SmokeTestLogList}" Margin="0,12,0,0" FontFamily="Consolas" FontSize="11"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- =================================================================== -->
        <!-- BOTTOM DIAGNOSTICS & LOG PANEL                                      -->
        <!-- =================================================================== -->
        <Border Grid.Row="2" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderTranslucentBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Panel Header -->
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="DIAGNOSTICS &amp; STRUCTURED LOGS" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI" FontWeight="Bold" FontSize="12"/>
                        <TextBlock Text="(Sanitized Payloads / Credentials Redacted)" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Segoe UI" FontSize="9" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="LIVE SUBSYSTEM OUTFLOW" Foreground="{DynamicResource WarningBrush}" FontWeight="Bold" FontSize="10" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Structured Log Grid -->
                <ListView Grid.Row="1" ItemsSource="{Binding DiagnosticService.Logs}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Timestamp" Width="150">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontFamily="Consolas"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Subsystem" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Subsystem}" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Level" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Level}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="INFO">
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Message" Width="780">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Message}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" FontFamily="Consolas"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Loading overlay with Smooth GPU continuous rotation transform -->
        <Border Grid.Row="0" Grid.RowSpan="3" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E50A0B0E"/>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="M12,4 V2 M12,20 V22 M4,12 H2 M20,12 H22 M18.36,5.64 L19.78,4.22 M5.64,18.36 L4.22,19.78 M18.36,18.36 L19.78,19.78 M5.64,5.64 L4.22,4.22"
                      Stroke="{DynamicResource AccentBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1.5"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                    <Path.RenderTransform>
                        <RotateTransform Angle="0"/>
                    </Path.RenderTransform>
                </Path>
                <TextBlock Text="{Binding BusyMessage}" Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                <TextBlock Text="Please wait..." Foreground="#888888" FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
