                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <StackPanel>
                                                    <TextBlock Text="EA INSTALLATION GUIDE / HELP" Style="{StaticResource EnterpriseHeader}"/>
                                                    <TextBlock Text="Follow these instructions to connect your MetaTrader 5 Terminal to NTE:" Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,12"/>

                                                    <TextBlock Text="1. Open MT5 Terminal Data Folder:" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,3"/>
                                                    <TextBlock Text="   Go to File -> Open Data Folder inside MT5." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,8"/>

                                                    <TextBlock Text="2. Copy the Expert Advisor file:" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,3"/>
                                                    <TextBlock Text="   Copy 'NexusBridge.mq5' from 'MQL5/Experts/Nexus/' to the data folder's 'MQL5/Experts/' directory." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,8"/>

                                                    <TextBlock Text="3. Compile the EA in MetaEditor:" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,3"/>
                                                    <TextBlock Text="   Open the file in MetaEditor and press Compile (F7)." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,8"/>

                                                    <TextBlock Text="4. Attach the EA to a chart:" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,3"/>
                                                    <TextBlock Text="   Drag 'NexusBridge' onto any chart. Set Host='127.0.0.1' and Port=5000." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,8"/>

                                                    <TextBlock Text="5. Enable Algorithmic Trading:" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,3"/>
                                                    <TextBlock Text="   Click the 'Algo Trading' button on the MT5 top toolbar." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,8"/>

                                                    <TextBlock Text="6. Verify connection logs:" FontWeight="Bold" Foreground="#00ADB5" Margin="0,0,0,3"/>
                                                    <TextBlock Text="   Check the 'Journal' and 'Experts' tabs in MT5 terminal toolbox." Style="{StaticResource EnterpriseBodyText}"/>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </TabItem>

                            <!-- Tab 2: Market Watch Symbol Subscription Manager -->
                            <TabItem>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="NEXUS REAL-TIME FEED WATCHLIST" Style="{StaticResource EnterpriseHeader}" Margin="0,0,0,5"/>
                                            <TextBlock Text="Manage active subscriptions for major currency pairs and spot metals. Ingest live market data continuously." Style="{StaticResource EnterpriseBodyText}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="15">
