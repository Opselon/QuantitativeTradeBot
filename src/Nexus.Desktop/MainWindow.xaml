                                                    <Setter Property="Background" Value="#393E46"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Padding" Value="8,6"/>
                                                    <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                </Style>
