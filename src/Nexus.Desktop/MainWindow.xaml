                                                <DataGridTextColumn Header="Ask price" Binding="{Binding Ask, StringFormat={}{0:F5}}" Width="120"/>
                                                <DataGridTextColumn Header="Spread" Binding="{Binding Spread, StringFormat={}{0:F5}}" Width="100"/>
                                                <DataGridTextColumn Header="Ticks Count" Binding="{Binding TickCount}" Width="110"/>
