                            <!-- Tab 4: Account Snapshot Metrics -->
                            <TabItem>
                                <Border Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="25">
                                    <StackPanel>
                                        <TextBlock Text="LIVE BROKER ACCOUNT SUMMARY" Style="{StaticResource EnterpriseHeader}"/>

                                        <Grid Margin="0,15,0,20">
