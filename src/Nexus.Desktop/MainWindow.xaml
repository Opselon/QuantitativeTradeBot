<Window x:Class="Nexus.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Nexus.Desktop.Converters"
        xmlns:views="clr-namespace:Nexus.Desktop.Views"
        Title="{Binding AppVersion, StringFormat='Nexus Trading Engine - Desktop Workstation v{0}'}"
        Height="780" Width="1120"
        Background="#121212"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Professional Dark Theme Styles & Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:EqualityToBooleanConverter x:Key="EqualityToBooleanConverter"/>

        <Style x:Key="EnterpriseHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="#00ADB5"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="EnterpriseSubHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="EnterpriseBodyText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
        </Style>

        <Style x:Key="EnterpriseLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="EnterpriseTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#222831"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#393E46"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#00ADB5"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00C4CC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#393E46"/>
                    <Setter Property="Foreground" Value="#777777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#393E46"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4F5661"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#222831"/>
                    <Setter Property="Foreground" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 1. Top Status Bar / Header -->
            <RowDefinition Height="Auto"/>
            <!-- 2. Main Workspace/Wizard Work Area -->
            <RowDefinition Height="*"/>
            <!-- 3. Bottom Diagnostics & Structured Log Panel -->
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- =================================================================== -->
        <!-- TOP STATUS BAR / Badge Bar                                          -->
        <!-- =================================================================== -->
        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="#393E46" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Application Brand Logo -->
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="⚡" Foreground="#00ADB5" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="NEXUS" Foreground="#EEEEEE" FontFamily="Segoe UI" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="TRADING ENGINE" Foreground="#888888" FontFamily="Segoe UI" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: Status / Badges -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                    <!-- Environment Badge -->
                    <Border Background="#D65A31" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                        <TextBlock Text="DEVELOPMENT / SIMULATION" Foreground="White" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <!-- Connection Status Badge -->
                    <Border CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2E7D32"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                        <Setter Property="Background" Value="#00ADB5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#4CAF50" Margin="0,0,4,0"/>
                            <TextBlock Foreground="White" FontSize="10" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="SIMULATOR ACTIVE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                                <Setter Property="Text" Value="REAL MT5 BRIDGE ACTIVE"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- Chosen Provider Badge -->
                    <Border Background="#00ADB5" CornerRadius="3" Padding="6,2">
                        <TextBlock Text="{Binding SelectedProvider}" Foreground="Black" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =================================================================== -->
        <!-- MAIN WORKSPACE                                                      -->
        <!-- =================================================================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left Navigation Bar -->
                <ColumnDefinition Width="180"/>
                <!-- Central Panel Workspace -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT NAVIGATION PANEL -->
            <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="0,0,1,0">
                <Grid Margin="10,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Navigation Items -->
                    <StackPanel Grid.Row="0">
                        <!-- Navigation Item Header -->
                        <TextBlock Text="WORKSPACE" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="5,0,0,10"/>

                        <!-- Onboarding Menu Link (Active during onboarding) -->
                        <Button Content="Onboarding Wizard" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="True" Background="#00ADB5" Foreground="Black" FontWeight="Bold">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOnboarded}" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#888888"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Dashboard Menu Link -->
                        <Button Content="Dashboard" Command="{Binding SelectDashboardCommand}" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                            <Setter Property="Background" Value="#222831"/>
                                            <Setter Property="Foreground" Value="#00ADB5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="MT5 Bridge" Command="{Binding SelectMt5BridgeCommand}" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                            <Setter Property="Background" Value="#222831"/>
                                            <Setter Property="Foreground" Value="#00ADB5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Market Watch" Command="{Binding SelectMarketWatchCommand}" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                            <Setter Property="Background" Value="#222831"/>
                                            <Setter Property="Foreground" Value="#00ADB5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Manual Desk" Command="{Binding SelectManualDeskCommand}" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                            <Setter Property="Background" Value="#222831"/>
                                            <Setter Property="Foreground" Value="#00ADB5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Account Metrics" Command="{Binding SelectAccountMetricsCommand}" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="4">
                                            <Setter Property="Background" Value="#222831"/>
                                            <Setter Property="Foreground" Value="#00ADB5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Native Engine" Command="{Binding SelectNativeEngineCommand}" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="5">
                                            <Setter Property="Background" Value="#222831"/>
                                            <Setter Property="Foreground" Value="#00ADB5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Diagnostics" Command="{Binding SelectDiagnosticsCommand}" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="6">
                                            <Setter Property="Background" Value="#222831"/>
                                            <Setter Property="Foreground" Value="#00ADB5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Settings" Command="{Binding SelectSettingsCommand}" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="7">
                                            <Setter Property="Background" Value="#222831"/>
                                            <Setter Property="Foreground" Value="#00ADB5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Test Console" Command="{Binding SelectTestConsoleCommand}" HorizontalContentAlignment="Left" Padding="8,6" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="8">
                                            <Setter Property="Background" Value="#222831"/>
                                            <Setter Property="Foreground" Value="#00ADB5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Footer Details -->
                    <StackPanel Grid.Row="1" Margin="5,0">
                        <TextBlock Text="SYSTEM READY" Foreground="#4CAF50" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding AppVersion, StringFormat='N NTE v{0}'}" Foreground="#444444" FontSize="9" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CENTRAL WORKSPACE PANEL -->
            <Border Grid.Column="1" Background="#222831" Padding="30,25">
                <Grid>
                    <!-- =============================================================== -->
                    <!-- ONBOARDING WIZARD SCREENS                                       -->
                    <!-- =============================================================== -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnboarded}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Wizard Progress Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="{Binding CurrentStep, StringFormat='ONBOARDING WIZARD - STEP {0} OF 6'}" Foreground="#888888" FontSize="11" FontWeight="Bold"/>
                            <ProgressBar Value="{Binding CurrentStep}" Minimum="1" Maximum="6" Height="4" Margin="0,6,0,0" Foreground="#00ADB5" Background="#393E46" BorderThickness="0"/>
                        </StackPanel>

                        <!-- Wizard Main Content Area (Provider Selection / Profile Input / Snapshot Preview) -->
                        <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="25">
                            <Grid>
                                <!-- STEP 1: Select Persistence Provider -->
                                <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Select Local Database Persistence Mode" Style="{StaticResource EnterpriseHeader}"/>
                                    <TextBlock Text="Choose how Nexus stores account credentials, trades, positions, and strategy configuration profiles." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,20"/>

                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Option A: PostgreSQL (Recommended) -->
                                        <Border Grid.Column="0" Background="#222831" BorderBrush="#00ADB5" BorderThickness="1" Padding="20,15" CornerRadius="4">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <RadioButton IsChecked="{Binding SelectedProvider, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=PostgreSQL}" GroupName="Provider" Content="PostgreSQL Server" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <Border Background="#2E7D32" CornerRadius="3" Padding="4,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="RECOMMENDED" Foreground="White" FontSize="8" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="• Production grade reliability and scalability." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,3"/>
                                                <TextBlock Text="• Supports high-throughput raw Binary COPY partitioning." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,3"/>
                                                <TextBlock Text="• Retains history across simulated system restarts." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,3"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Option B: SQLite (Quick Start) -->
                                        <Border Grid.Column="2" Background="#222831" BorderBrush="#393E46" BorderThickness="1" Padding="20,15" CornerRadius="4">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <RadioButton IsChecked="{Binding SelectedProvider, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=SQLite}" GroupName="Provider" Content="SQLite" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <Border Background="#393E46" CornerRadius="3" Padding="4,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="QUICK START" Foreground="White" FontSize="8" FontWeight="Bold"/>
                                                </Border>
                                                </StackPanel>
                                                <TextBlock Text="• Local self-contained file database." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,3"/>
                                                <TextBlock Text="• Zero configuration or system requirements." Style="{StaticResource EnterpriseBodyText}" Margin="5,0,0,3"/>
                                                <TextBlock Text="• Perfect for local evaluation, UI exploration, and debugging." Style="{StaticResource ResourceKey=EnterpriseBodyText}" Margin="5,0,0,3"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="PostgreSQL is recommended for production enterprise environments. Ensure your database server is running." Foreground="#E2C044" FontSize="11" Margin="0,5,0,0"/>
                                </StackPanel>

                                <!-- STEP 2: Configure & Initialize Database -->
                                <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Initialize Selected Persistence Path" Style="{StaticResource EnterpriseHeader}"/>
                                    <TextBlock Text="Verify and prepare the tables, indexes, and database schemas required for algorithmic execution." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,20"/>

                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Connection String:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,15"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,15"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Status Indicator:" Style="{StaticResource EnterpriseLabel}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DatabaseStatus}" Foreground="#00ADB5" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Initialize Database" Command="{Binding InitializeDbCommand}" Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
                                        <Button Content="Apply Migrations" Command="{Binding MigrateDbCommand}" Style="{StaticResource SecondaryButton}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- STEP 3: Create MT5 Connection Profile -->
                                <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="MetaTrader 5 Onboarding Credentials" Style="{StaticResource EnterpriseHeader}"/>
                                    <TextBlock Text="Configure connection details to route orders and download snapshots. Sensitive passwords are saved securely using ISecretStore." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,15"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Profile Name & Server -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile Name:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Server / Broker:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding BrokerServer, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <!-- Row 1: Login & Password -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Login / Account ID:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LoginAccountId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Password (Masked):" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <!-- Using standard textbox with masked binding or direct binding, password is redacted in saved summaries -->
                                        <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <!-- Row 2: Terminal Path -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="MT5 Terminal Path:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding TerminalPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <!-- Row 3: Timeout & Reconnect -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Timeout (Seconds):" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,12"/>

                                        <TextBlock Grid.Row="3" Grid.Column="3" Text="Auto Reconnect:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <CheckBox Grid.Row="3" Grid.Column="4" IsChecked="{Binding AutoReconnect}" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,12"/>

                                        <!-- Row 4: Mode Selection (Simulated vs Real Bridge) -->
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="MT5 Bridge Mode:" Style="{StaticResource EnterpriseLabel}" Margin="0,0,0,12"/>
                                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                                            <RadioButton Content="Simulated MT5" IsChecked="{Binding Mt5Mode, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=Simulated}" Foreground="White" GroupName="Mt5ModeGroup" Margin="0,0,15,0"/>
                                            <RadioButton Content="Real MT5 Bridge" IsChecked="{Binding Mt5Mode, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=Real}" Foreground="White" GroupName="Mt5ModeGroup"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Conditional Real Bridge Configuration Fields -->
                                    <Border Background="#222831" BorderBrush="#393E46" BorderThickness="1" Padding="15" CornerRadius="4" Margin="0,12,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="REAL BRIDGE ENDPOINT CONFIGURATION" Foreground="#00ADB5" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Bridge Host (IP):" Style="{StaticResource EnterpriseLabel}"/>
