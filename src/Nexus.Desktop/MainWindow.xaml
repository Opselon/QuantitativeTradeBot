                                            <TextBlock Text="VERIFICATION PROTOCOL" Foreground="#888888" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Target Broker:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BrokerServer}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Account ID:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LoginAccountId}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Outcome Status:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TestOutcome}" Foreground="#E2C044" FontSize="13" FontWeight="Bold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Test MT5 Connection" Command="{Binding TestConnectionCommand}" Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
                                        <TextBlock Foreground="#888888" VerticalAlignment="Center" FontSize="11" FontStyle="Italic">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="(Simulated connector fallback is active)"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                                            <Setter Property="Text" Value="(Will wait for connection from MQL5 Expert Advisor)"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- STEP 5: Account Preview Snapshot -->
                                <StackPanel Visibility="{Binding IsStep5, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Broker Account Live Snapshot Preview" Style="{StaticResource EnterpriseHeader}"/>
