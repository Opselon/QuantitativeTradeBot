                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Welcome column -->
                                    <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="Welcome to Nexus Trading Engine!" Style="{StaticResource EnterpriseHeader}"/>
                                            <TextBlock Text="NTE is a real-time, low-latency institutional algorithmic trading desk. Use the left navigation panel to access different terminal views." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,15"/>
                                            <TextBlock Text="✓ Real MT5 Bridge Ready" Foreground="#4CAF50" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <TextBlock Text="✓ Native C++ Math Acceleration Active" Foreground="#4CAF50" FontWeight="Bold" Margin="0,0,0,5"/>
                                            <TextBlock Text="✓ Multi-Instrument Symbol Subscriptions Enabled" Foreground="#4CAF50" FontWeight="Bold" Margin="0,0,0,5"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Quick Stats column -->
                                    <Border Grid.Column="2" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="LIVE TELEMETRY SUMMARY" Style="{StaticResource EnterpriseHeader}"/>

                                            <Grid Margin="0,5,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Bridge Connection:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BridgeConnectionStatusText}" Foreground="#00ADB5" FontWeight="Bold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Ping Latency:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BridgePingLatencyMs, StringFormat={}{0:F2} ms}" Foreground="#E2C044" FontWeight="Bold" FontFamily="Consolas"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Total Ticks Ingested:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ProcessedTickCount}" Foreground="#4CAF50" FontWeight="Bold" FontFamily="Consolas"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- Tab 1: MT5 Bridge & Instructions -->
                            <TabItem>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="NEXUS MT5 LOCALHOST BRIDGE CONTROL" Style="{StaticResource EnterpriseHeader}" Margin="0,0,0,5"/>
                                                <TextBlock Text="Establish local bridge sockets, authenticate credentials, and monitor connection health." Style="{StaticResource EnterpriseBodyText}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left Panel: Connection Settings -->
                                        <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="15">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <StackPanel>
                                                    <TextBlock Text="CONNECTION CONFIGURATION" Style="{StaticResource EnterpriseSubHeader}" Margin="0,0,0,10"/>

                                                    <TextBlock Text="Bridge Endpoint Host:" Style="{StaticResource EnterpriseLabel}" Margin="0,5,0,4"/>
