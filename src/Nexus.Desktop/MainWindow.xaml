                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Account ID Login:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.AccountId}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Broker Server:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.BrokerServer}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Account Mode:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.AccountMode}" Foreground="#00ADB5" FontSize="12" FontWeight="SemiBold"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Right side metrics -->
                                            <StackPanel Grid.Column="2">
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Live Account Balance:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Balance, StringFormat={}{0:C2}}" Foreground="#4CAF50" FontSize="14" FontWeight="Bold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Live Equity value:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Equity, StringFormat={}{0:C2}}" Foreground="#4CAF50" FontSize="14" FontWeight="Bold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Free Margin:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.FreeMargin, StringFormat={}{0:C2}}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <Button Content="REFRESH METRICS" Command="{Binding BridgeRefreshAccountCommand}" Style="{StaticResource ActionButton}"/>
                                    </StackPanel>
                                </Border>
                            </TabItem>

                            <!-- Tab 5: Native Engine / Intel -->
                            <TabItem>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="380"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Panel: Native core telemetry details -->
                                    <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="NATIVE ACCELERATION PERFORMANCE DIAGNOSTICS" Style="{StaticResource EnterpriseHeader}"/>

                                            <Grid Margin="0,15,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Total Processed Ticks:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ProcessedTickCount}" Foreground="#4CAF50" FontSize="14" FontWeight="Bold" FontFamily="Consolas"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Last Processed Symbol:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastProcessedSymbol}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Processing Latency:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastProcessingLatencyMs, StringFormat={}{0:F4} ms}" Foreground="#00ADB5" FontSize="13" FontWeight="Bold" FontFamily="Consolas"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Last update timestamp:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastProcessedTimestampText}" Foreground="White" FontSize="11" FontFamily="Consolas"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Right Panel: The Neural view -->
                                    <views:NexusIntelligenceDashboard Grid.Column="2" DataContext="{Binding Intelligence}"/>
                                </Grid>
                            </TabItem>

                            <!-- Tab 6: Diagnostics -->
                            <TabItem>
                                <Border Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="SYSTEM DIAGNOSTICS &amp; BOUNDED LOGS" Style="{StaticResource EnterpriseHeader}"/>
                                        <!-- Displays recent log entries directly in-view -->
                                        <ListView Grid.Row="1" ItemsSource="{Binding DiagnosticService.Logs}" Background="#121212" BorderBrush="#393E46" Foreground="White" Margin="0,10,0,0">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Timestamp" DisplayMemberBinding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" Width="120"/>
                                                    <GridViewColumn Header="Subsystem" DisplayMemberBinding="{Binding Subsystem}" Width="110"/>
                                                    <GridViewColumn Header="Level" DisplayMemberBinding="{Binding Level}" Width="70"/>
                                                    <GridViewColumn Header="Diagnostic Message" DisplayMemberBinding="{Binding Message}" Width="520"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <!-- Tab 7: Settings -->
                            <TabItem>
                                <Border Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="NEXUS TRADING PLATFORM CONFIGURATION" Style="{StaticResource EnterpriseHeader}"/>
                                        <TextBlock Text="Manage local database options and general application settings." Style="{StaticResource EnterpriseBodyText}" Margin="0,5,0,20"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Active Database Provider:" Style="{StaticResource EnterpriseLabel}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedProvider}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </TabItem>

                            <!-- Tab 8: Test Console & Real Smoke Test Workflow -->
                            <TabItem>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left side: Run Smoke Test Controls -->
                                    <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="REAL LOCALHOST BRIDGE PIPELINE VERIFIER" Style="{StaticResource EnterpriseHeader}"/>
                                            <TextBlock Text="Press the button below to run an automated, live integration smoke test that connects, authenticates, pings, subscribes, monitors EURUSD ticks, and disconnects cleanly." Style="{StaticResource EnterpriseBodyText}" Margin="0,5,0,20"/>

                                            <Button Content="RUN AUTOMATED REAL SMOKE TEST" Command="{Binding RunSmokeTestCommand}" Style="{StaticResource ActionButton}" Padding="20,12" FontSize="12" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                                            <Border BorderBrush="#393E46" BorderThickness="0,1,0,0" Margin="0,5,0,15"/>

                                            <TextBlock Text="LIGHTWEIGHT DIAGNOSTICS API" Style="{StaticResource EnterpriseSubHeader}" Margin="0,0,0,10"/>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Connection Status:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BridgeConnectionStatusText}" Foreground="#00ADB5" FontSize="12" FontWeight="Bold"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Auth Status:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding IsBridgeAuthenticated}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Ping Latency:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BridgePingLatencyMs, StringFormat={}{0:F2} ms}" Foreground="#E2C044" FontSize="11" FontFamily="Consolas" FontWeight="Bold"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Total Processed Ticks:" Style="{StaticResource EnterpriseLabel}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ProcessedTickCount}" Foreground="#4CAF50" FontSize="11" FontFamily="Consolas" FontWeight="Bold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Right side: Real-time progress logs -->
                                    <Border Grid.Column="2" Background="#1E1E1E" BorderBrush="#393E46" BorderThickness="1" CornerRadius="4" Padding="15">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="SMOKE TEST CONSOLE WORKFLOW LOG" Style="{StaticResource EnterpriseHeader}"/>
                                            <ListView Grid.Row="1" ItemsSource="{Binding SmokeTestLogList}" Background="#121212" BorderBrush="#393E46" Foreground="#EEEEEE" Margin="0,10,0,0" FontFamily="Consolas" FontSize="11"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- =================================================================== -->
        <!-- BOTTOM DIAGNOSTICS & LOG PANEL                                      -->
        <!-- =================================================================== -->
        <Border Grid.Row="2" Background="#111111" BorderBrush="#393E46" BorderThickness="0,1,0,0">
            <Grid Margin="12,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Panel Header -->
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="DIAGNOSTICS &amp; STRUCTURED LOGS" Foreground="#EEEEEE" FontFamily="Segoe UI" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Text="(Sanitized Payloads / Credentials Redacted)" Foreground="#555555" FontFamily="Segoe UI" FontSize="9" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="LIVE" Foreground="#D65A31" FontWeight="Bold" FontSize="9" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Structured Log Grid -->
                <ListView Grid.Row="1" ItemsSource="{Binding DiagnosticService.Logs}" Background="#1A1A1A" BorderBrush="#393E46" BorderThickness="1" Foreground="#EEEEEE">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Timestamp" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}" Foreground="#888888" FontSize="11" FontFamily="Consolas"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Subsystem" Width="110">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Subsystem}" Foreground="#00ADB5" FontSize="11" FontWeight="Bold"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Level" Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Level}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#EEEEEE"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                            <Setter Property="Foreground" Value="#D65A31"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                            <Setter Property="Foreground" Value="#E2C044"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="INFO">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Message" Width="680">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Message}" Foreground="#DDDDDD" FontSize="11" FontFamily="Consolas"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#AA121212" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⚡" Foreground="#00ADB5" FontSize="48" HorizontalAlignment="Center">
                    <TextBlock.RenderTransform>
                        <RotateTransform Angle="0" x:Name="SpinnerTransform" CenterX="24" CenterY="24"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock Text="{Binding BusyMessage}" Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                <TextBlock Text="Please wait..." Foreground="#888888" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
