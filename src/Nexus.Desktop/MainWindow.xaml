<Window x:Class="Nexus.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Nexus.Desktop.Converters"
        xmlns:views="clr-namespace:Nexus.Desktop.Views"
        xmlns:workspaces="clr-namespace:Nexus.Desktop.Views.Workspaces"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding AppVersion, StringFormat='Nexus Trading Engine - Desktop Workstation v{0}'}"
        Height="900" Width="1440"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Tag="False">

    <!-- Leverage standard WPF WindowChrome to fully support window resizing, maximizing, and standard frame borders -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64" ResizeBorderThickness="8" CornerRadius="16" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:EqualityToBooleanConverter x:Key="EqualityToBooleanConverter"/>
    </Window.Resources>

    <Border BorderThickness="1.5" BorderBrush="{DynamicResource GlassBorderBrush}" CornerRadius="16" ClipToBounds="True">
        <Grid Background="{DynamicResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <!-- 1. Elegant Title Bar & App Header -->
                <RowDefinition Height="64"/>
                <!-- 2. Onboarding Progress or Action Indicator -->
                <RowDefinition Height="Auto"/>
                <!-- 3. Workstation main dashboard workspace body -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- =================================================================== -->
            <!-- 1. CUSTOM SYSTEM TITLE BAR                                          -->
            <!-- =================================================================== -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceContainerBrush}" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Institutional Branding Logo -->
                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ChartTimelineVariant" Width="26" Height="26" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="NEXUS" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Style="{StaticResource NteDisplayLarge}"/>
                        <TextBlock Text="INTELLIGENCE TERMINAL" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Style="{StaticResource NteBodyMedium}"/>
                    </StackPanel>

                    <!-- Center: System Badges / Live connection health -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="{DynamicResource PrimaryContainerBrush}" CornerRadius="20" Padding="12,6" Margin="0,0,12,0" BorderThickness="1" BorderBrush="{DynamicResource PrimaryBrush}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Server" Width="14" Height="14" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding SelectedProvider}" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="20" Padding="12,6" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#102515"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryContainerBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True">
                                            <!-- Light Theme Trigger -->
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Tag}" Value="True"/>
                                                <Condition Binding="{Binding Mt5Mode}" Value="Real"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource PrimaryContainerBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                                    <Setter Property="Fill" Value="{DynamicResource PrimaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="SIMULATOR ACTIVE"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Mt5Mode}" Value="Real">
                                                    <Setter Property="Text" Value="REAL MT5 BRIDGE ACTIVE"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right: Window controls + Theme Toggle -->
                    <!-- Elements are marked with WindowChrome.IsHitTestVisibleInChrome="True" so they receive user click/touch events in Custom Titlebar -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- Theme Toggle Button -->
                        <ToggleButton x:Name="ThemeToggle" Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" ToolTip="Toggle Visual Palette Theme" Margin="0,0,15,0" Checked="ThemeToggle_Checked" Unchecked="ThemeToggle_Unchecked">
                            <materialDesign:PackIcon Kind="WeatherSunny" Width="20" Height="20" x:Name="ThemeIcon"/>
                        </ToggleButton>

                        <Button Width="32" Height="32" Padding="0" Style="{StaticResource MaterialDesignIconButton}" Click="Minimize_Click" Margin="0,0,4,0">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                        <Button Width="32" Height="32" Padding="0" Style="{StaticResource MaterialDesignIconButton}" Click="Maximize_Click" Margin="0,0,4,0">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="18" Height="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                        <Button Width="32" Height="32" Padding="0" Style="{StaticResource MaterialDesignIconButton}" Click="Close_Click" materialDesign:RippleAssist.Feedback="#EF4444">
                            <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="#EF4444"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- =================================================================== -->
            <!-- 2. MAIN WORKSPACE ASSEMBLY                                          -->
            <!-- =================================================================== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <!-- Sidebar Navigation Drawer -->
                    <ColumnDefinition Width="260"/>
                    <!-- Central Panel Workspace -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT GLASS-LIKE NAVIGATION DRAWER -->
                <Border Grid.Column="0" Background="{DynamicResource SurfaceContainerBrush}" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="15,25">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Navigation Items -->
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="QUANT WORKSTATION" Style="{StaticResource NteLabelSmall}" Margin="12,0,0,15"/>

                            <!-- Onboarding Wizard Button -->
                            <Button HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,6" IsEnabled="True">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NtePremiumButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOnboarded}" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="HelpCircle" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Onboarding Wizard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Navigation Tabs Mapping -->
                            <!-- Dashboard -->
                            <Button Command="{Binding SelectDashboardCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>

                            <!-- MT5 Bridge -->
                            <Button Command="{Binding SelectMt5BridgeCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Bridge" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="MT5 Bridge" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>

                            <!-- Market Watch -->
                            <Button Command="{Binding SelectMarketWatchCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Eye" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Market Watch" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>

                            <!-- Manual Desk -->
                            <Button Command="{Binding SelectManualDeskCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AttachMoney" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Manual Desk" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>

                            <!-- Account Metrics -->
                            <Button Command="{Binding SelectAccountMetricsCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="4">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Account" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Account Metrics" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>

                            <!-- Native Engine -->
                            <Button Command="{Binding SelectNativeEngineCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="5">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ChartLine" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Native Engine" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>

                            <!-- Diagnostics -->
                            <Button Command="{Binding SelectDiagnosticsCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="6">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldCheck" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Diagnostics" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>

                            <!-- Settings -->
                            <Button Command="{Binding SelectSettingsCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="7">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cog" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Settings" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>


                            <!-- NEW: POSITION MANAGER WORKSTATION SIDEBAR BUTTON -->
                            <!-- Command Input: Binds to SelectPositionManagerCommand on MainViewModel -->
                            <!-- UI Trigger: Highlights with PrimaryBrush when SelectedTabIndex == 10 -->
                            <Button Command="{Binding SelectPositionManagerCommand}" 
        HorizontalContentAlignment="Left" 
        Height="40" 
        Padding="12,0" 
        Margin="0,0,0,3" 
        IsEnabled="{Binding IsOnboarded}"
        ToolTip="Open Independent Position Manager Cockpit &amp; Risk Tuning Desk">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="10">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldLock" Width="18" Height="18" Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Position Manager" VerticalAlignment="Center" FontWeight="Bold" Foreground="#F59E0B" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>

                            <!-- Train Skills -->


                            <Button Command="{Binding SelectTrainSkillsCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="9">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Brain" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Train Skills" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>

                            <!-- Test Console -->
                            <Button Command="{Binding SelectTestConsoleCommand}" HorizontalContentAlignment="Left" Height="46" Padding="15,0" Margin="0,0,0,4" IsEnabled="{Binding IsOnboarded}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NteSecondaryButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="8">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Console" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Test Console" VerticalAlignment="Center" Style="{StaticResource NteBodyLarge}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Footer metadata -->
                        <StackPanel Grid.Row="1" Margin="10,0">
                            <TextBlock Text="SYSTEM SECURE" Foreground="{DynamicResource SuccessBrush}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding AppVersion, StringFormat='N NTE Core v{0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" Margin="0,4,0,0" Style="{StaticResource NteLabelSmall}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CENTRAL MAIN WORKSPACE -->
                <Grid Grid.Column="1" Margin="30,25">
                    <!-- =============================================================== -->
                    <!-- ONBOARDING WIZARD INTERFACES                                    -->
                    <!-- =============================================================== -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnboarded}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Wizard Progress Indicator -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,25">
                            <TextBlock Text="{Binding CurrentStep, StringFormat='SYSTEM ONBOARDING MODULES - STEP {0} OF 6'}" Style="{StaticResource NteLabelLarge}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                            <ProgressBar Value="{Binding CurrentStep}" Minimum="1" Maximum="6" Height="6" Foreground="{DynamicResource PrimaryBrush}" Background="{DynamicResource SurfaceVariantBrush}"/>
                        </StackPanel>

                        <!-- Wizard Card Container -->
                        <materialDesign:Card Grid.Row="1" Style="{StaticResource NtePremiumCard}">
                            <Grid>
                                <!-- STEP 1: DB persistence selection -->
                                <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Select Database Persistence Layer" Style="{StaticResource NteHeadline}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Select the local persistence provider used for securing algorithmic profiles, MT5 credential snapshots, and audit logs." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,25"/>

                                    <Grid Margin="0,0,0,25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Option A: PostgreSQL -->
                                        <materialDesign:Card Grid.Column="0" Style="{StaticResource NtePremiumCard}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                    <RadioButton IsChecked="{Binding SelectedProvider, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=PostgreSQL}" GroupName="ProviderGroup" Content="PostgreSQL Server" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <Border Background="{DynamicResource SuccessBrush}" CornerRadius="12" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="RECOMMENDED" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="• Production grade reliability and database partitioning." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,6"/>
                                                <TextBlock Text="• Retains history accurately across system restarts." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,6"/>
                                                <TextBlock Text="• Supports high-throughput Raw SQL schema mappings." Style="{StaticResource NteBodyMedium}"/>
                                            </StackPanel>
                                        </materialDesign:Card>

                                        <!-- Option B: SQLite -->
                                        <materialDesign:Card Grid.Column="2" Style="{StaticResource NtePremiumCard}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                    <RadioButton IsChecked="{Binding SelectedProvider, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=SQLite}" GroupName="ProviderGroup" Content="SQLite" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="QUICK START" Foreground="{DynamicResource BackgroundBrush}" FontSize="9" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="• Zero configuration local self-contained database." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,6"/>
                                                <TextBlock Text="• Ideal for debugging, UI exploration, and offline evaluation." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,6"/>
                                                <TextBlock Text="• Writes binary schemas with no system server requirements." Style="{StaticResource NteBodyMedium}"/>
                                            </StackPanel>
                                        </materialDesign:Card>
                                    </Grid>

                                    <TextBlock Text="Note: Ensure your selected persistence provider database server is running prior to initiating tables." Foreground="{DynamicResource WarningBrush}" FontWeight="Bold" Style="{StaticResource NteBodyMedium}"/>
                                </StackPanel>

                                <!-- STEP 2: DB schema tables initialization -->
                                <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Database Tables Schema Initialization" Style="{StaticResource NteHeadline}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Validate connection string parameters and configure table definitions, indexes, and concurrency mechanisms." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,25"/>

                                    <Grid Margin="0,0,0,25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Connection String:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Initialization Status:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DatabaseStatus}" Foreground="{DynamicResource PrimaryBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="INITIALIZE DATABASE" Command="{Binding InitializeDbCommand}" Style="{StaticResource NtePremiumButton}" Margin="0,0,15,0"/>
                                        <Button Content="APPLY SCHEMAS" Command="{Binding MigrateDbCommand}" Style="{StaticResource NteSecondaryButton}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- STEP 3: MT5 Connection Profile -->
                                <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Configure MetaTrader 5 Connection Profile" Style="{StaticResource NteHeadline}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Sensitive broker passwords and endpoints are encrypted securely using dynamic WindowsSecretStore APIs." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,20"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="15"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="15"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="15"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="15"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Profile Name & Server -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile Identifier:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}"/>

                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Server / Broker:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding BrokerServer, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}"/>

                                        <!-- Login & Password -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Account Login ID:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LoginAccountId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="3" Text="Password (Redacted):" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}"/>

                                        <!-- Terminal Path -->
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="MT5 exe File Path:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding TerminalPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}"/>

                                        <!-- Timeout & Auto Reconnect -->
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Timeout (Seconds):" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NteFloatingHintTextBox}"/>

                                        <TextBlock Grid.Row="6" Grid.Column="3" Text="Gateway Connection:" Style="{StaticResource NteLabelLarge}" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="6" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <RadioButton Content="Simulation Mode" IsChecked="{Binding Mt5Mode, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=Simulated}" GroupName="WizardMt5Mode" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,15,0"/>
                                            <RadioButton Content="Real Bridge" IsChecked="{Binding Mt5Mode, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=Real}" GroupName="WizardMt5Mode" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- STEP 4: Test Connection -->
                                <StackPanel Visibility="{Binding IsStep4, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Verify MT5 Gateway Handshake Connection" Style="{StaticResource NteHeadline}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Execute end-to-end bidirectional handshake tests targeting terminal sockets and listener ports." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,25"/>

                                    <materialDesign:Card Style="{StaticResource NtePremiumCard}" Margin="0,0,0,25">
                                        <StackPanel>
                                            <TextBlock Text="PORT HANDSHAKE CRITERIA" Style="{StaticResource NteLabelLarge}" Margin="0,0,0,15"/>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Server:" Style="{StaticResource NteLabelLarge}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BrokerServer}" Style="{StaticResource NteBodyLarge}" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Broker ID Account:" Style="{StaticResource NteLabelLarge}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LoginAccountId}" Style="{StaticResource NteBodyLarge}" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Diagnostic Result:" Style="{StaticResource NteLabelLarge}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TestOutcome}" Foreground="{DynamicResource WarningBrush}" FontSize="14" FontWeight="Bold"/>
                                            </Grid>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="TEST GATEWAY CONNECTION" Command="{Binding TestConnectionCommand}" Style="{StaticResource NtePremiumButton}" Margin="0,0,15,0"/>
                                        <TextBlock Text="(Simulation Mode will verify offline. Real Bridge mode executes real socket listens.)" Style="{StaticResource NteBodyMedium}" FontStyle="Italic" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- STEP 5: Account preview metrics -->
                                <StackPanel Visibility="{Binding IsStep5, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Broker Account Active Snapshot" Style="{StaticResource NteHeadline}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Successfully established gateway socket. Financial metrics snapshot parsed successfully from broker response." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,25"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <materialDesign:Card Grid.Column="0" Style="{StaticResource NtePremiumCard}">
                                            <StackPanel>
                                                <TextBlock Text="BALANCE ACCOUNT BALANCES" Style="{StaticResource NteLabelLarge}" Margin="0,0,0,15"/>

                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Primary Balance:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Balance, StringFormat={}{0:C2}}" Foreground="{DynamicResource SuccessBrush}" FontSize="15" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Liquidity Equity:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Equity, StringFormat={}{0:C2}}" Foreground="{DynamicResource SuccessBrush}" FontSize="15" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Free Margin:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.FreeMargin, StringFormat={}{0:C2}}" Style="{StaticResource NteTradingDataFont}" FontWeight="SemiBold"/>
                                                </Grid>
                                            </StackPanel>
                                        </materialDesign:Card>

                                        <materialDesign:Card Grid.Column="2" Style="{StaticResource NtePremiumCard}">
                                            <StackPanel>
                                                <TextBlock Text="BROKER ACCOUNT METADATA" Style="{StaticResource NteLabelLarge}" Margin="0,0,0,15"/>

                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Account ID:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.AccountId}" Style="{StaticResource NteBodyLarge}" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Leverage Structure:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Leverage, StringFormat='1:{0}'}" Style="{StaticResource NteBodyLarge}" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Account Mode:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.AccountMode}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" Style="{StaticResource NteBodyLarge}"/>
                                                </Grid>
                                            </StackPanel>
                                        </materialDesign:Card>
                                    </Grid>
                                </StackPanel>

                                <!-- STEP 6: Launch -->
                                <StackPanel Visibility="{Binding IsStep6, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Initialize Workstation Dashboard Terminal" Style="{StaticResource NteHeadline}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Onboarding profiles generated. You are now authorized to initiate core quant analytics engines and ticks subscription routers." Style="{StaticResource NteBodyMedium}" Margin="0,0,0,25"/>

                                    <Border Background="{DynamicResource SuccessBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,25" Opacity="0.9">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ShieldCheck" Width="32" Height="32" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                            <StackPanel>
                                                <TextBlock Text="Workspace Handshake Completed Successfully" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                                <TextBlock Text="Configurations stored safely in local AppSettings. Local database persistence layer initialized." Foreground="#E2E8F0" FontSize="11" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Button Content="LAUNCH TRADING DESK WORKSTATION" Command="{Binding LaunchWorkspaceCmd}" Style="{StaticResource NtePremiumButton}"/>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>

                        <!-- Wizard Footer Actions -->
                        <DockPanel Grid.Row="2" Margin="0,25,0,0">
                            <Button Content="PREVIOUS STEP" Command="{Binding BackCommand}" Style="{StaticResource NteSecondaryButton}" DockPanel.Dock="Left"/>

                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button Content="NEXT STEP" Command="{Binding SelectProviderNextCommand}" Style="{StaticResource NtePremiumButton}" Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="NEXT STEP" Command="{Binding DbNextCommand}" Style="{StaticResource NtePremiumButton}" Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="NEXT STEP" Command="{Binding CreateProfileNextCommand}" Style="{StaticResource NtePremiumButton}" Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="NEXT STEP" Command="{Binding TestNextCommand}" Style="{StaticResource NtePremiumButton}" Visibility="{Binding IsStep4, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="NEXT STEP" Command="{Binding AccountNextCommand}" Style="{StaticResource NtePremiumButton}" Visibility="{Binding IsStep5, Converter={StaticResource BoolToVisConverter}}"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>

                    <!-- =============================================================== -->
                    <!-- ACTIVE WORKSPACE INTERFACE                                      -->
                    <!-- =============================================================== -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnboarded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Background="Transparent" BorderThickness="0" Padding="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </TabControl.Resources>

                            <!-- Tab 0: Dashboard -->
                            <TabItem>
                                <workspaces:DashboardView DataContext="{Binding Dashboard}"/>
                            </TabItem>

                            <!-- Tab 1: MT5 Bridge -->
                            <TabItem>
                                <workspaces:Mt5BridgeView DataContext="{Binding Mt5Bridge}"/>
                            </TabItem>

                            <!-- Tab 2: Market Watch -->
                            <TabItem>
                                <workspaces:MarketWatchView DataContext="{Binding MarketWatch}"/>
                            </TabItem>

                            <!-- Tab 3: Manual Desk -->
                            <TabItem>
                                <workspaces:ManualDeskView DataContext="{Binding ManualDesk}"/>
                            </TabItem>

                            <!-- Tab 4: Account Metrics -->
                            <TabItem>
                                <materialDesign:Card Style="{StaticResource NtePremiumCard}">
                                    <StackPanel>
                                        <TextBlock Text="LIVE BROKER ACCOUNT SUMMARY" Style="{StaticResource NteHeadline}" Margin="0,0,0,25"/>

                                        <Grid Margin="0,0,0,25">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Left side -->
                                            <StackPanel Grid.Column="0">
                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Account ID Login:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.AccountId}" Style="{StaticResource NteBodyLarge}" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Broker Server:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.BrokerServer}" Style="{StaticResource NteBodyLarge}" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Account Mode:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.AccountMode}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" Style="{StaticResource NteBodyLarge}"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Right side -->
                                            <StackPanel Grid.Column="2">
                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Live Account Balance:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Balance, StringFormat={}{0:C2}}" Foreground="{DynamicResource SuccessBrush}" FontSize="16" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Live Equity value:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Equity, StringFormat={}{0:C2}}" Foreground="{DynamicResource SuccessBrush}" FontSize="16" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Free Margin:" Style="{StaticResource NteLabelLarge}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.FreeMargin, StringFormat={}{0:C2}}" Style="{StaticResource NteTradingDataFont}" FontWeight="SemiBold"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <Button Content="REFRESH FINANCIAL SNAPSHOT" Command="{Binding BridgeRefreshAccountCommand}" Style="{StaticResource NtePremiumButton}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </TabItem>

                            <!-- Tab 5: Native Engine -->
                            <TabItem>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="420"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Panel -->
                                    <materialDesign:Card Grid.Column="0" Style="{StaticResource NtePremiumCard}">
                                        <StackPanel>
                                            <TextBlock Text="NATIVE C++ MATH PERFORMANCE DIAGNOSTICS" Style="{StaticResource NteHeadline}" Margin="0,0,0,25"/>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <!-- Corrected: ColumnDefinition was missing its prefix -->
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Total Ingested Ticks:" Style="{StaticResource NteLabelLarge}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ProcessedTickCount}" Foreground="{DynamicResource SuccessBrush}" FontSize="16" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Last Processed Instrument:" Style="{StaticResource NteLabelLarge}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastProcessedSymbol}" Style="{StaticResource NteBodyLarge}" FontWeight="SemiBold"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Ingestion Latency Duration:" Style="{StaticResource NteLabelLarge}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastProcessingLatencyMs, StringFormat={}{0:F4} ms}" Foreground="{DynamicResource PrimaryBrush}" FontSize="14" FontWeight="Bold" Style="{StaticResource NteTradingDataFont}"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Pipeline Updated Time:" Style="{StaticResource NteLabelLarge}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastProcessedTimestampText}" Style="{StaticResource NteTradingDataFont}"/>
                                            </Grid>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- Right Panel: The Neural view -->
                                    <views:NexusIntelligenceDashboard Grid.Column="2" DataContext="{Binding Intelligence}"/>
                                </Grid>
                            </TabItem>
                            
                            

                            <!-- Tab 6: Diagnostics -->
                            <TabItem>
                                <workspaces:DiagnosticsView DataContext="{Binding Diagnostics}"/>
                            </TabItem>

                            <!-- Tab 7: Settings -->
                            <TabItem>
                                <workspaces:SettingsView DataContext="{Binding Settings}"/>
                            </TabItem>

                            
                            <!-- Tab 8: Test Console -->
                            <TabItem>
                                <workspaces:TestConsoleView DataContext="{Binding TestConsole}"/>
                            </TabItem>


                            <TabItem>
                                <workspaces:TrainSkillsView DataContext="{Binding TrainSkills}"/>
                            </TabItem>
                            <!-- NEW: TAB 10 - POSITION MANAGER WORKSTATION -->
                            <!-- DataContext Mapping: Binds directly to MainViewModel.PositionManager -->
                            <!-- View Element: Renders the PositionManagerView workspace -->
                            <TabItem>
                                <workspaces:PositionManagerView DataContext="{Binding PositionManager}"/>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>