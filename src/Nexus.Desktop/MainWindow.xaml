                                                    <TextBlock Text="Bridge Endpoint Port:" Style="{StaticResource EnterpriseLabel}" Margin="0,5,0,4"/>
                                                    <TextBox Text="{Binding Mt5BridgePort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,15"/>

                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <Button Content="START BRIDGE LISTENER" Command="{Binding BridgeConnectCommand}" Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
                                                        <Button Content="STOP BRIDGE LISTENER" Command="{Binding BridgeDisconnectCommand}" Style="{StaticResource SecondaryButton}"/>
                                                    </StackPanel>

                                                    <Border BorderBrush="#393E46" BorderThickness="0,1,0,0" Margin="0,5,0,15"/>

                                                    <TextBlock Text="SECURE LOGIN CREDENTIALS" Style="{StaticResource EnterpriseSubHeader}" Margin="0,0,0,10"/>

                                                    <TextBlock Text="Account ID / Login ID:" Style="{StaticResource EnterpriseLabel}" Margin="0,5,0,4"/>
                                                    <TextBox Text="{Binding LoginAccountId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,10"/>

                                                    <TextBlock Text="Broker Password / Secret:" Style="{StaticResource EnterpriseLabel}" Margin="0,5,0,4"/>
                                                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,10"/>

                                                    <TextBlock Text="Broker Server Name:" Style="{StaticResource EnterpriseLabel}" Margin="0,5,0,4"/>
                                                    <TextBox Text="{Binding BrokerServer, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnterpriseTextBox}" Margin="0,0,0,15"/>

                                                    <Button Content="SECURE AUTHORIZE" Command="{Binding BridgeLoginCommand}" Style="{StaticResource ActionButton}"/>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>

                                        <!-- Right Panel: EA Installation Guide -->
