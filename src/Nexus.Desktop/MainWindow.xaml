                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Account ID:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.AccountId}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Server:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.BrokerServer}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Leverage:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.Leverage, StringFormat='1:{0}'}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Account Mode:" Style="{StaticResource EnterpriseLabel}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AccountSnapshot.AccountMode}" Foreground="#00ADB5" FontSize="12" FontWeight="SemiBold"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <!-- STEP 6: Launch Workstation Workspace -->
                                <StackPanel Visibility="{Binding IsStep6, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="Ready to Launch Trading Station" Style="{StaticResource EnterpriseHeader}"/>
                                    <TextBlock Text="Onboarding is complete! You can now launch the dashboard workspace. Active credentials, settings, and parameters have been fully persisted." Style="{StaticResource EnterpriseBodyText}" Margin="0,0,0,20"/>

                                    <Border Background="#2E7D32" CornerRadius="4" Padding="15" Margin="0,0,0,20">
